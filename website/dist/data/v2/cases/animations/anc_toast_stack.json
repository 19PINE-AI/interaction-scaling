{"id": "anc_toast_stack", "modality": "animations", "name": "Toast Stack", "task": {"description": "Create a self-contained 1920x1080 HTML animation (inline CSS, NO <canvas>) of toast notifications. Over ~4s, FOUR equal-width toasts slide in from the RIGHT edge one at a time and stack vertically in the top-right corner (newest on top, with uniform vertical gaps and a fixed right margin). Each toast has an icon, a title, and a close affordance.", "requirements": ["Each toast stays fully within the viewport at every frame (none clipped at the right edge once settled)", "Toasts appear one at a time (more visible in later frames)", "Stacked toasts do not overlap each other", "All toasts share the same right edge and width (right-aligned, equal width)", "Stacked toasts have uniform vertical gaps between them", "By the final frame all four toasts are visible and stacked in the top-right"], "difficulty": "hard"}, "runs": [{"run": 1, "ss_n_defects": 6, "ss_text_overlap": null, "ss_clipped": null, "ss_overflow": null, "ss_total_tokens": 2711, "rv_n_defects": 24, "rv_text_overlap": null, "rv_clipped": null, "rv_overflow": null, "rv_iterations": 3, "rv_total_tokens": 16189}, {"run": 2, "ss_n_defects": 30, "ss_text_overlap": null, "ss_clipped": null, "ss_overflow": null, "ss_total_tokens": 2697, "rv_n_defects": 3, "rv_text_overlap": null, "rv_clipped": null, "rv_overflow": null, "rv_iterations": 1, "rv_total_tokens": 2299}, {"run": 3, "ss_n_defects": 30, "ss_text_overlap": null, "ss_clipped": null, "ss_overflow": null, "ss_total_tokens": 2675, "rv_n_defects": 26, "rv_text_overlap": null, "rv_clipped": null, "rv_overflow": null, "rv_iterations": 3, "rv_total_tokens": 16678}], "ss_img": "images/animations/anc_toast_stack_ss.jpg", "rv_img": "images/animations/anc_toast_stack_rv.jpg", "ss_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Toast Notifications Animation</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: 1920px;\n            height: 1080px;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            overflow: hidden;\n            position: relative;\n        }\n\n        .toast-container {\n            position: absolute;\n            top: 32px;\n            right: 32px;\n            width: 400px;\n            z-index: 1000;\n        }\n\n        .toast {\n            width: 400px;\n            height: 80px;\n            background: #ffffff;\n            border-radius: 12px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);\n            display: flex;\n            align-items: center;\n            padding: 16px 20px;\n            margin-bottom: 16px;\n            position: relative;\n            transform: translateX(450px);\n            opacity: 0;\n            border-left: 4px solid #4CAF50;\n        }\n\n        .toast.success {\n            border-left-color: #4CAF50;\n        }\n\n        .toast.warning {\n            border-left-color: #FF9800;\n        }\n\n        .toast.error {\n            border-left-color: #F44336;\n        }\n\n        .toast.info {\n            border-left-color: #2196F3;\n        }\n\n        .toast-icon {\n            width: 24px;\n            height: 24px;\n            margin-right: 16px;\n            flex-shrink: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            border-radius: 50%;\n            font-weight: bold;\n            font-size: 14px;\n            color: white;\n        }\n\n        .toast.success .toast-icon {\n            background: #4CAF50;\n        }\n\n        .toast.warning .toast-icon {\n            background: #FF9800;\n        }\n\n        .toast.error .toast-icon {\n            background: #F44336;\n        }\n\n        .toast.info .toast-icon {\n            background: #2196F3;\n        }\n\n        .toast-content {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n        }\n\n        .toast-title {\n            font-size: 16px;\n            font-weight: 600;\n            color: #1a1a1a;\n            line-height: 1.2;\n            margin-bottom: 4px;\n        }\n\n        .toast-message {\n            font-size: 14px;\n            color: #666666;\n            line-height: 1.3;\n        }\n\n        .toast-close {\n            width: 24px;\n            height: 24px;\n            margin-left: 16px;\n            flex-shrink: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            cursor: pointer;\n            border-radius: 4px;\n            color: #999999;\n            font-size: 18px;\n            font-weight: bold;\n            transition: all 0.2s ease;\n        }\n\n        .toast-close:hover {\n            background: #f5f5f5;\n            color: #666666;\n        }\n\n        /* Animation keyframes */\n        @keyframes slideInFromRight {\n            from {\n                transform: translateX(450px);\n                opacity: 0;\n            }\n            to {\n                transform: translateX(0);\n                opacity: 1;\n            }\n        }\n\n        @keyframes stackShift {\n            from {\n                transform: translateY(0);\n            }\n            to {\n                transform: translateY(96px);\n            }\n        }\n\n        /* Animation classes */\n        .toast.animate-in {\n            animation: slideInFromRight 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;\n        }\n\n        .toast.shift-down {\n            animation: stackShift 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;\n        }\n\n        /* Stacking positions */\n        .toast:nth-child(1) { z-index: 104; }\n        .toast:nth-child(2) { z-index: 103; }\n        .toast:nth-child(3) { z-index: 102; }\n        .toast:nth-child(4) { z-index: 101; }\n    </style>\n</head>\n<body>\n    <div class=\"toast-container\" id=\"toastContainer\">\n        <div class=\"toast success\" id=\"toast1\">\n            <div class=\"toast-icon\">\u2713</div>\n            <div class=\"toast-content\">\n                <div class=\"toast-title\">Upload Complete</div>\n                <div class=\"toast-message\">Your file has been uploaded successfully</div>\n            </div>\n            <div class=\"toast-close\">\u00d7</div>\n        </div>\n\n        <div class=\"toast warning\" id=\"toast2\">\n            <div class=\"toast-icon\">!</div>\n            <div class=\"toast-content\">\n                <div class=\"toast-title\">Storage Warning</div>\n                <div class=\"toast-message\">You're running low on storage space</div>\n            </div>\n            <div class=\"toast-close\">\u00d7</div>\n        </div>\n\n        <div class=\"toast error\" id=\"toast3\">\n            <div class=\"toast-icon\">\u2715</div>\n            <div class=\"toast-content\">\n                <div class=\"toast-title\">Connection Failed</div>\n                <div class=\"toast-message\">Unable to connect to the server</div>\n            </div>\n            <div class=\"toast-close\">\u00d7</div>\n        </div>\n\n        <div class=\"toast info\" id=\"toast4\">\n            <div class=\"toast-icon\">i</div>\n            <div class=\"toast-content\">\n                <div class=\"toast-title\">New Update Available</div>\n                <div class=\"toast-message\">Version 2.1.0 is ready to install</div>\n            </div>\n            <div class=\"toast-close\">\u00d7</div>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const toasts = document.querySelectorAll('.toast');\n            const animationDuration = 4000; // 4 seconds total\n            const delayBetweenToasts = animationDuration / toasts.length; // 1 second between each\n\n            function animateToast(index) {\n                if (index >= toasts.length) return;\n\n                const currentToast = toasts[index];\n                \n                // Shift existing toasts down\n                for (let i = 0; i < index; i++) {\n                    const existingToast = toasts[i];\n                    existingToast.style.transform = `translateY(${(index - i) * 96}px)`;\n                    existingToast.style.transition = 'transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n                }\n\n                // Animate current toast in\n                setTimeout(() => {\n                    currentToast.classList.add('animate-in');\n                }, 50);\n\n                // Schedule next toast\n                setTimeout(() => {\n                    animateToast(index + 1);\n                }, delayBetweenToasts);\n            }\n\n            // Start the animation sequence\n            setTimeout(() => {\n                animateToast(0);\n            }, 500);\n\n            // Add click handlers for close buttons\n            toasts.forEach(toast => {\n                const closeBtn = toast.querySelector('.toast-close');\n                closeBtn.addEventListener('click', () => {\n                    toast.style.transform = 'translateX(450px)';\n                    toast.style.opacity = '0';\n                    toast.style.transition = 'all 0.3s ease';\n                });\n            });\n        });\n    </script>\n</body>\n</html>", "rv_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Toast Notifications Animation</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: 1920px;\n            height: 1080px;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            overflow: hidden;\n            position: relative;\n        }\n\n        .toast-container {\n            position: absolute;\n            top: 32px;\n            right: 32px;\n            width: 400px;\n            z-index: 1000;\n        }\n\n        .toast {\n            width: 400px;\n            background: #ffffff;\n            border-radius: 12px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);\n            padding: 20px;\n            margin-bottom: 16px;\n            display: flex;\n            align-items: center;\n            gap: 16px;\n            position: absolute;\n            transform: translateX(450px);\n            opacity: 0;\n            border-left: 4px solid;\n            height: 64px;\n        }\n\n        .toast.success {\n            border-left-color: #10b981;\n        }\n\n        .toast.warning {\n            border-left-color: #f59e0b;\n        }\n\n        .toast.error {\n            border-left-color: #ef4444;\n        }\n\n        .toast.info {\n            border-left-color: #3b82f6;\n        }\n\n        .toast-icon {\n            width: 24px;\n            height: 24px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            font-size: 14px;\n            color: white;\n            flex-shrink: 0;\n        }\n\n        .toast.success .toast-icon {\n            background: #10b981;\n        }\n\n        .toast.warning .toast-icon {\n            background: #f59e0b;\n        }\n\n        .toast.error .toast-icon {\n            background: #ef4444;\n        }\n\n        .toast.info .toast-icon {\n            background: #3b82f6;\n        }\n\n        .toast-content {\n            flex: 1;\n        }\n\n        .toast-title {\n            font-size: 16px;\n            font-weight: 600;\n            color: #1f2937;\n            line-height: 1.4;\n        }\n\n        .toast-close {\n            width: 24px;\n            height: 24px;\n            border: none;\n            background: #f3f4f6;\n            border-radius: 6px;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 14px;\n            color: #6b7280;\n            flex-shrink: 0;\n            transition: background-color 0.2s ease;\n        }\n\n        .toast-close:hover {\n            background: #e5e7eb;\n        }\n\n        /* Initial positions - all start off-screen */\n        #toast1 {\n            top: 0;\n            transform: translateX(450px);\n            opacity: 0;\n        }\n\n        #toast2 {\n            top: 0;\n            transform: translateX(450px);\n            opacity: 0;\n        }\n\n        #toast3 {\n            top: 0;\n            transform: translateX(450px);\n            opacity: 0;\n        }\n\n        #toast4 {\n            top: 0;\n            transform: translateX(450px);\n            opacity: 0;\n        }\n\n        /* Animation keyframes for sliding in */\n        @keyframes slideIn {\n            0% {\n                transform: translateX(450px);\n                opacity: 0;\n            }\n            100% {\n                transform: translateX(0);\n                opacity: 1;\n            }\n        }\n\n        /* Animation keyframes for moving down */\n        @keyframes moveDown80 {\n            0% {\n                top: 0;\n            }\n            100% {\n                top: 80px;\n            }\n        }\n\n        @keyframes moveDown160 {\n            0% {\n                top: 80px;\n            }\n            100% {\n                top: 160px;\n            }\n        }\n\n        @keyframes moveDown240 {\n            0% {\n                top: 160px;\n            }\n            100% {\n                top: 240px;\n            }\n        }\n\n        @keyframes moveFrom0To160 {\n            0% {\n                top: 0;\n            }\n            100% {\n                top: 160px;\n            }\n        }\n\n        @keyframes moveFrom0To240 {\n            0% {\n                top: 0;\n            }\n            100% {\n                top: 240px;\n            }\n        }\n\n        @keyframes moveFrom80To240 {\n            0% {\n                top: 80px;\n            }\n            100% {\n                top: 240px;\n            }\n        }\n\n        /* Animation classes */\n        .slide-in {\n            animation: slideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n        }\n\n        .move-down-80 {\n            animation: moveDown80 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n        }\n\n        .move-down-160 {\n            animation: moveDown160 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n        }\n\n        .move-down-240 {\n            animation: moveDown240 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n        }\n\n        .move-0-to-160 {\n            animation: moveFrom0To160 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n        }\n\n        .move-0-to-240 {\n            animation: moveFrom0To240 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n        }\n\n        .move-80-to-240 {\n            animation: moveFrom80To240 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"toast-container\">\n        <div class=\"toast success\" id=\"toast1\">\n            <div class=\"toast-icon\">\u2713</div>\n            <div class=\"toast-content\">\n                <div class=\"toast-title\">File uploaded successfully</div>\n            </div>\n            <button class=\"toast-close\">\u00d7</button>\n        </div>\n\n        <div class=\"toast warning\" id=\"toast2\">\n            <div class=\"toast-icon\">!</div>\n            <div class=\"toast-content\">\n                <div class=\"toast-title\">Storage space running low</div>\n            </div>\n            <button class=\"toast-close\">\u00d7</button>\n        </div>\n\n        <div class=\"toast error\" id=\"toast3\">\n            <div class=\"toast-icon\">\u00d7</div>\n            <div class=\"toast-content\">\n                <div class=\"toast-title\">Connection failed to server</div>\n            </div>\n            <button class=\"toast-close\">\u00d7</button>\n        </div>\n\n        <div class=\"toast info\" id=\"toast4\">\n            <div class=\"toast-icon\">i</div>\n            <div class=\"toast-content\">\n                <div class=\"toast-title\">New update available</div>\n            </div>\n            <button class=\"toast-close\">\u00d7</button>\n        </div>\n    </div>\n\n    <script>\n        function animateToasts() {\n            const toast1 = document.getElementById('toast1');\n            const toast2 = document.getElementById('toast2');\n            const toast3 = document.getElementById('toast3');\n            const toast4 = document.getElementById('toast4');\n\n            // Toast 1 slides in at top (t=0)\n            setTimeout(() => {\n                toast1.classList.add('slide-in');\n            }, 0);\n\n            // Toast 2 slides in, toast 1 moves down (t=1000ms)\n            setTimeout(() => {\n                toast1.classList.add('move-down-80');\n                toast2.classList.add('slide-in');\n            }, 1000);\n\n            // Toast 3 slides in, toast 1 moves to position 3, toast 2 moves down (t=2000ms)\n            setTimeout(() => {\n                toast1.classList.remove('move-down-80');\n                toast1.classList.add('move-0-to-160');\n                toast2.classList.add('move-down-80');\n                toast3.classList.add('slide-in');\n            }, 2000);\n\n            // Toast 4 slides in, all others move down (t=3000ms)\n            setTimeout(() => {\n                toast1.classList.remove('move-0-to-160');\n                toast1.classList.add('move-0-to-240');\n                toast2.classList.remove('move-down-80');\n                toast2.classList.add('move-80-to-240');\n                toast3.classList.add('move-down-80');\n                toast4.classList.add('slide-in');\n            }, 3000);\n        }\n\n        // Start animation when page loads\n        window.addEventListener('load', () => {\n            setTimeout(animateToasts, 500);\n        });\n\n        // Add click handlers for close buttons\n        document.querySelectorAll('.toast-close').forEach(button => {\n            button.addEventListener('click', (e) => {\n                e.preventDefault();\n                // Just for demo - in real app would remove the toast\n            });\n        });\n    </script>\n</body>\n</html>"}