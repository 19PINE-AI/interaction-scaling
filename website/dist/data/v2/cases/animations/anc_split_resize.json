-out infinite;\n            box-shadow: 0 0 8px rgba(74, 144, 226, 0.3);\n        }\n\n        .divider::before {\n            content: '';\n            position: absolute;\n            left: -8px;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 20px;\n            height: 60px;\n            background: #4a90e2;\n            border-radius: 10px;\n            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);\n        }\n\n        .pane-header {\n            padding: 32px;\n            border-bottom: 2px solid #e9ecef;\n            background: linear-gradient(90deg, #4a90e2, #357abd);\n            color: white;\n        }\n\n        .pane-title {\n            font-size: 28px;\n            font-weight: 700;\n            margin-bottom: 8px;\n            letter-spacing: -0.5px;\n        }\n\n        .pane-subtitle {\n            font-size: 16px;\n            opacity: 0.9;\n            font-weight: 400;\n        }\n\n        .pane-content {\n            padding: 32px;\n            height: calc(100% - 120px);\n            overflow-y: auto;\n        }\n\n        .list-item {\n            padding: 20px 24px;\n            border-bottom: 1px solid #e9ecef;\n            transition: all 0.2s ease;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 16px;\n        }\n\n        .list-item:hover {\n            background: #f8f9fa;\n            transform: translateX(4px);\n        }\n\n        .list-item:last-child {\n            border-bottom: none;\n        }\n\n        .item-icon {\n            width: 40px;\n            height: 40px;\n            border-radius: 8px;\n            background: linear-gradient(135deg, #4a90e2, #357abd);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            flex-shrink: 0;\n        }\n\n        .item-content {\n            flex: 1;\n            min-width: 0;\n        }\n\n        .item-title {\n            font-size: 18px;\n            font-weight: 600;\n            color: #2c3e50;\n            margin-bottom: 4px;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n        }\n\n        .item-description {\n            font-size: 14px;\n            color: #6c757d;\n            line-height: 1.4;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n        }\n\n        .detail-section {\n            margin-bottom: 32px;\n        }\n\n        .detail-section h3 {\n            font-size: 24px;\n            font-weight: 700;\n            color: #2c3e50;\n            margin-bottom: 16px;\n            padding-bottom: 8px;\n            border-bottom: 2px solid #4a90e2;\n        }\n\n        .detail-text {\n            font-size: 16px;\n            line-height: 1.6;\n            color: #495057;\n            margin-bottom: 16px;\n        }\n\n        .detail-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n            gap: 16px;\n            margin-top: 24px;\n        }\n\n        .detail-card {\n            background: white;\n            padding: 20px;\n            border-radius: 8px;\n            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\n            border-left: 4px solid #4a90e2;\n        }\n\n        .detail-card h4 {\n            font-size: 18px;\n            font-weight: 600;\n            color: #2c3e50;\n            margin-bottom: 8px;\n        }\n\n        .detail-card p {\n            font-size: 14px;\n            color: #6c757d;\n            line-height: 1.4;\n        }\n\n        @keyframes leftPaneResize {\n            0%, 100% {\n                width: 30%;\n            }\n            50% {\n                width: 60%;\n            }\n        }\n\n        @keyframes dividerMove {\n            0%, 100% {\n                left: 30%;\n            }\n            50% {\n                left: 60%;\n            }\n        }\n\n        .right-pane .pane-header {\n            background: linear-gradient(90deg, #6c757d, #495057);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"left-pane\">\n            <div class=\"pane-header\">\n                <div class=\"pane-title\">Project List</div>\n                <div class=\"pane-subtitle\">Active development projects</div>\n            </div>\n            <div class=\"pane-content\">\n                <div class=\"list-item\">\n                    <div class=\"item-icon\">A</div>\n                    <div class=\"item-content\">\n                        <div class=\"item-title\">Analytics Dashboard</div>\n                        <div class=\"item-description\">Real-time data visualization and reporting system</div>\n                    </div>\n                </div>\n                <div class=\"list-item\">\n                    <div class=\"item-icon\">M</div>\n                    <div class=\"item-content\">\n                        <div class=\"item-title\">Mobile Application</div>\n                        <div class=\"item-description\">Cross-platform mobile app for customer engagement</div>\n                    </div>\n                </div>\n                <div class=\"list-item\">\n                    <div class=\"item-icon\">E</div>\n                    <div class=\"item-content\">\n                        <div class=\"item-title\">E-commerce Platform</div>\n                        <div class=\"item-description\">Modern online shopping experience with AI recommendations</div>\n                    </div>\n                </div>\n                <div class=\"list-item\">\n                    <div class=\"item-icon\">C</div>\n                    <div class=\"item-content\">\n                        <div class=\"item-title\">Cloud Infrastructure</div>\n                        <div class=\"item-description\">Scalable cloud architecture and deployment automation</div>\n                    </div>\n                </div>\n                <div class=\"list-item\">\n                    <div class=\"item-icon\">S</div>\n                    <div class=\"item-content\">\n                        <div class=\"item-title\">Security Framework</div>\n                        <div class=\"item-description\">Enterprise-grade security protocols and monitoring</div>\n                    </div>\n                </div>\n                <div class=\"list-item\">\n                    <div class=\"item-icon\">U</div>\n                    <div class=\"item-content\">\n                        <div class=\"item-title\">User Experience Redesign</div>\n                        <div class=\"item-description\">Complete UI/UX overhaul for improved usability</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"divider\"></div>\n\n        <div class=\"right-pane\">\n            <div class=\"pane-header\">\n                <div class=\"pane-title\">Project Details</div>\n                <div class=\"pane-subtitle\">Comprehensive project information</div>\n            </div>\n            <div class=\"pane-content\">\n                <div class=\"detail-section\">\n                    <h3>Overview</h3>\n                    <p class=\"detail-text\">\n                        This comprehensive project management system provides detailed insights into all active development initiatives. \n                        Each project includes timeline tracking, resource allocation, and progress monitoring capabilities.\n                    </p>\n                    <p class=\"detail-text\">\n                        The system integrates with multiple development tools and provides real-time updates on project status, \n                        team collaboration metrics, and delivery milestones.\n                    </p>\n                </div>\n\n                <div class=\"detail-section\">\n                    <h3>Key Features</h3>\n                    <div class=\"detail-grid\">\n                        <div class=\"detail-card\">\n                            <h4>Real-time Tracking</h4>\n                            <p>Monitor project progress with live updates and automated status reporting.</p>\n                        </div>\n                        <div class=\"detail-card\">\n                            <h4>Team Collaboration</h4>\n                            <p>Integrated communication tools and shared workspace for seamless teamwork.</p>\n                        </div>\n                        <div class=\"detail-card\">\n                            <h4>Resource Management</h4>\n                            <p>Optimize resource allocation and track utilization across all projects.</p>\n                        </div>\n                        <div class=\"detail-card\">\n                            <h4>Analytics & Reporting</h4>\n                            <p>Comprehensive analytics dashboard with customizable reports and insights.</p>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"detail-section\">\n                    <h3>Technical Specifications</h3>\n                    <p class=\"detail-text\">\n                        Built on modern web technologies with a focus on performance, scalability, and maintainability. \n                        The architecture supports microservices deployment and cloud-native infrastructure.\n                    </p>\n                    <p class=\"detail-text\">\n                        Features include responsive design, offline capabilities, and enterprise-grade security \n                        with role-based access control and audit logging.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </div>\n</body>\n</html>"}