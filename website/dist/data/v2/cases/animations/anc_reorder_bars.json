slateX(220px); }  /* 85 -> position 6 */\n        .animate .bar:nth-child(4) { transform: translateX(-220px); } /* 25 -> position 0 */\n        .animate .bar:nth-child(5) { transform: translateX(-220px); } /* 75 -> position 4 */\n        .animate .bar:nth-child(6) { transform: translateX(-220px); } /* 55 -> position 3 */\n\n        .subtitle {\n            color: rgba(255, 255, 255, 0.8);\n            font-size: 24px;\n            margin-top: 60px;\n            text-align: center;\n            font-style: italic;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"title\">Data Visualization: Ascending Order Animation</div>\n    \n    <div class=\"chart-container\" id=\"chartContainer\">\n        <div class=\"bar\">\n            <div class=\"bar-value\">65</div>\n            <div class=\"bar-label\">Product A</div>\n        </div>\n        <div class=\"bar\">\n            <div class=\"bar-value\">35</div>\n            <div class=\"bar-label\">Product B</div>\n        </div>\n        <div class=\"bar\">\n            <div class=\"bar-value\">85</div>\n            <div class=\"bar-label\">Product C</div>\n        </div>\n        <div class=\"bar\">\n            <div class=\"bar-value\">25</div>\n            <div class=\"bar-label\">Product D</div>\n        </div>\n        <div class=\"bar\">\n            <div class=\"bar-value\">75</div>\n            <div class=\"bar-label\">Product E</div>\n        </div>\n        <div class=\"bar\">\n            <div class=\"bar-value\">55</div>\n            <div class=\"bar-label\">Product F</div>\n        </div>\n        <div class=\"baseline\"></div>\n    </div>\n\n    <div class=\"subtitle\">Watch as the bars smoothly reorder from left to right by ascending height</div>\n\n    <script>\n        // Start animation after a brief delay\n        setTimeout(() => {\n            document.getElementById('chartContainer').classList.add('animate');\n        }, 1000);\n\n        // Reset animation every 6 seconds for continuous demo