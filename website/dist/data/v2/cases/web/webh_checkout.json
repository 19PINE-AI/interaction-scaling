n            <div class=\"line-item\">\n                <div class=\"item-details\">\n                    <div class=\"item-name\">Premium Wireless Headphones</div>\n                    <div class=\"item-qty\">Qty: 1</div>\n                </div>\n                <div class=\"item-price\">$89.00</div>\n            </div>\n\n            <div class=\"line-item\">\n                <div class=\"item-details\">\n                    <div class=\"item-name\">Bluetooth Speaker</div>\n                    <div class=\"item-qty\">Qty: 1</div>\n                </div>\n                <div class=\"item-price\">$45.00</div>\n            </div>\n\n            <div class=\"line-item\">\n                <div class=\"item-details\">\n                    <div class=\"item-name\">USB-C Cable</div>\n                    <div class=\"item-qty\">Qty: 2</div>\n                </div>\n                <div class=\"item-price\">$38.00</div>\n            </div>\n\n            <div class=\"promo-section\">\n                <div class=\"promo-input\">\n                    <input type=\"text\" placeholder=\"Promo code\">\n                    <button class=\"promo-btn\">Apply</button>\n                </div>\n            </div>\n\n            <div class=\"summary-line\">\n                <span>Subtotal</span>\n                <span>$172.00</span>\n            </div>\n\n            <div class=\"summary-line\">\n                <span>Shipping</span>\n                <span>$8.00</span>\n            </div>\n\n            <div class=\"summary-line total\">\n                <span>Total</span>\n                <span>$180.00</span>\n            </div>\n\n            <button class=\"pay-button\">Pay $180.00</button>\n        </div>\n    </div>\n</body>\n</html>", "rv_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Checkout</title>\n    <style>\n        * {\n            margin: 0;\n  