em:hover {\n            background: #f8f9fa;\n        }\n\n        .conversation-item.active {\n            background: #e0e7ff;\n            border-right: 3px solid #6366f1;\n        }\n\n        .avatar {\n            width: 48px;\n            height: 48px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, #6366f1, #8b5cf6);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            font-size: 18px;\n            margin-right: 12px;\n            flex-shrink: 0;\n        }\n\n        .conversation-content {\n            flex: 1;\n            min-width: 0;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n        }\n\n        .conversation-top {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 4px;\n        }\n\n        .contact-name {\n            font-weight: 600;\n            font-size: 16px;\n            color: #1f2937;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            flex: 1;\n            margin-right: 8px;\n        }\n\n        .conversation-time {\n            font-size: 12px;\n            color: #6b7280;\n            white-space: nowrap;\n            flex-shrink: 0;\n        }\n\n        .last-message {\n            font-size: 14px;\n            color: #6b7280;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            margin-bottom: 2px;\n        }\n\n        .conversation-bottom {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n\n        .unread-badge {\n            background: #ef4444;\n            color: white;\n            border-radius: 12px;\n            padding: 2px 8px;\n            font-size: 12px;\n            font-weight: 600;\n            min-width: 20px;\n            text-align: center;\n            flex-shrink: 0;\n        }\n\n        /* RIGHT PANEL - Chat Thread */\n        .chat-panel {\n            flex: 1;\n            width: calc(100% - 320px);\n            display: flex;\n            flex-direction: column;\n            background: #ffffff;\n            height: 100vh;\n        }\n\n        .chat-header {\n            padding: 20px 24px;\n            border-bottom: 1px solid #e9ecef;\n            display: flex;\n            align-items: center;\n            background: white;\n            height: 80px;\n        }\n\n        .back-button {\n            display: none;\n            background: none;\n            border: none;\n            font-size: 20px;\n            color: #6366f1;\n            margin-right: 16px;\n            cursor: pointer;\n            padding: 8px;\n            border-radius: 8px;\n        }\n\n        .back-button:hover {\n            background: #f3f4f6;\n        }\n\n        .chat-avatar {\n            width: 40px;\n            height: 40px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, #10b981, #059669);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            margin-right: 12px;\n        }\n\n        .chat-contact-info {\n            flex: 1;\n        }\n\n        .chat-contact-name {\n            font-weight: 600;\n            font-size: 18px;\n            color: #1f2937;\n            margin-bottom: 2px;\n        }\n\n        .online-status {\n            display: flex;\n            align-items: center;\n            font-size: 14px;\n            color: #10b981;\n        }\n\n        .online-dot {\n            width: 8px;\n            height: 8px;\n            background: #10b981;\n            border-radius: 50%;\n            margin-right: 6px;\n        }\n\n        .messages-area {\n            flex: 1;\n            overflow-y: auto;\n            padding: 24px;\n            background: #f8f9fa;\n        }\n\n        .message {\n            display: flex;\n            margin-bottom: 16px;\n            align-items: flex-end;\n        }\n\n        .message.incoming {\n            justify-content: flex-start;\n        }\n\n        .message.outgoing {\n            justify-content: flex-end;\n        }\n\n        .message-bubble {\n            max-width: 60%;\n            padding: 12px 16px;\n            border-radius: 18px;\n            font-size: 15px;\n            line-height: 1.4;\n            word-wrap: break-word;\n            overflow-wrap: break-word;\n        }\n\n        .message.incoming .message-bubble {\n            background: white;\n            color: #1f2937;\n            border-bottom-left-radius: 4px;\n            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);\n        }\n\n        .message.outgoing .message-bubble {\n            background: #6366f1;\n            color: white;\n            border-bottom-right-radius: 4px;\n        }\n\n        .message-time {\n            font-size: 12px;\n            color: #9ca3af;\n            margin: 4px 8px 0;\n            white-space: nowrap;\n            flex-shrink: 0;\n        }\n\n        .composer {\n            padding: 20px 24px;\n            border-top: 1px solid #e9ecef;\n            background: white;\n            display: flex;\n            align-items: center;\n            gap: 12px;\n            height: 84px;\n        }\n\n        .composer-input {\n            flex: 1;\n            padding: 12px 16px;\n            border: 1px solid #d1d5db;\n            border-radius: 24px;\n            font-size: 15px;\n            outline: none;\n            resize: none;\n            max-height: 120px;\n            min-height: 44px;\n        }\n\n        .composer-input:focus {\n            border-color: #6366f1;\n            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);\n        }\n\n        .send-button {\n            width: 44px;\n            height: 44px;\n            background: #6366f1;\n            border: none;\n            border-radius: 50%;\n            color: white;\n            font-size: 18px;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: background-color 0.2s;\n            flex-shrink: 0;\n        }\n\n        .send-button:hover {\n            background: #5856eb;\n        }\n\n        .send-button:disabled {\n            background: #d1d5db;\n            cursor: not-allowed;\n        }\n\n        /* Mobile Responsive */\n        @media (max-width: 375px) {\n            .conversation-panel {\n                display: none;\n            }\n\n            .back-button {\n                display: block;\n            }\n\n            .chat-panel {\n                width: 100%;\n            }\n\n            .chat-header {\n                padding: 16px;\n                height: 72px;\n            }\n\n            .messages-area {\n                padding: 16px;\n            }\n\n            .message {\n                margin-bottom: 16px;\n            }\n\n            .message-bubble {\n                max-width: 85%;\n                word-wrap: break-word;\n                overflow-wrap: break-word;\n                hyphens: auto;\n                font-size: 14px;\n                padding: 10px 14px;\n            }\n\n            .message-time {\n                font-size: 11px;\n                margin: 4px 6px 0;\n                white-space: nowrap;\n                overflow: hidden;\n                text-overflow: ellipsis;\n                max-width: 60px;\n            }\n\n            .composer {\n                padding: 16px;\n                gap: 8px;\n                height: 72px;\n            }\n\n            .composer-input {\n                min-width: 0;\n                flex: 1;\n                font-size: 14px;\n                padding: 10px 14px;\n                min-height: 40px;\n            }\n\n            .send-button {\n                width: 40px;\n                height: 40px;\n                font-size: 16px;\n            }\n\n            .chat-contact-name {\n                font-size: 16px;\n                white-space: nowrap;\n                overflow: hidden;\n                text-overflow: ellipsis;\n            }\n\n            .online-status {\n                font-size: 12px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"app-container\">\n        <!-- LEFT PANEL - Conversation List -->\n        <div class=\"conversation-panel\">\n            <div class=\"conversation-header\">\n                <h1 class=\"app-title\">Pulse</h1>\n                <div class=\"search-box\">\n                    <input type=\"text\" class=\"search-input\" placeholder=\"Search conversations...\">\n                </div>\n            </div>\n            \n            <div class=\"conversation-list\">\n                <div class=\"conversation-item active\">\n                    <div class=\"avatar\">SM</div>\n                    <div class=\"conversation-content\">\n                        <div class=\"conversation-top\">\n                            <span class=\"contact-name\">Sarah Miller</span>\n                            <span class=\"conversation-time\">2:34 PM</span>\n                        </div>\n                        <div class=\"last-message\">Hey! Are we still on for lunch tomorrow?</div>\n                        <div class=\"conversation-bottom\">\n                            <span></span>\n                            <span class=\"unread-badge\">2</span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"conversation-item\">\n                    <div class=\"avatar\">JD</div>\n                    <div class=\"conversation-content\">\n                        <div class=\"conversation-top\">\n                            <span class=\"contact-name\">John Davis</span>\n                            <span class=\"conversation-time\">1:15 PM</span>\n                        </div>\n                        <div class=\"last-message\">Perfect! I'll send the files over shortly.</div>\n                        <div class=\"conversation-bottom\">\n                            <span></span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"conversation-item\">\n                    <div class=\"avatar\">EW</div>\n                    <div class=\"conversation-content\">\n                        <div class=\"conversation-top\">\n                            <span class=\"contact-name\">Emily Wilson</span>\n                            <span class=\"conversation-time\">11:42 AM</span>\n                        </div>\n                        <div class=\"last-message\">Thanks for the quick response! \ud83d\udc4d</div>\n                        <div class=\"conversation-bottom\">\n                            <span></span>\n                            <span class=\"unread-badge\">1</span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"conversation-item\">\n                    <div class=\"avatar\">MB</div>\n                    <div class=\"conversation-content\">\n                        <div class=\"conversation-top\">\n                            <span class=\"contact-name\">Mike Brown</span>\n                            <span class=\"conversation-time\">Yesterday</span>\n                        </div>\n                        <div class=\"last-message\">Let me know when you're free to discuss the project</div>\n                        <div class=\"conversation-bottom\">\n                            <span></span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"conversation-item\">\n                    <div class=\"avatar\">LJ</div>\n                    <div class=\"conversation-content\">\n                        <div class=\"conversation-top\">\n                            <span class=\"contact-name\">Lisa Johnson</span>\n                            <span class=\"conversation-time\">Yesterday</span>\n                        </div>\n                        <div class=\"last-message\">Great meeting today! Looking forward to next steps.</div>\n                        <div class=\"conversation-bottom\">\n                            <span></span>\n                            <span class=\"unread-badge\">5</span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"conversation-item\">\n                    <div class=\"avatar\">RT</div>\n                    <div class=\"conversation-content\">\n                        <div class=\"conversation-top\">\n                            <span class=\"contact-name\">Robert Taylor</span>\n                            <span class=\"conversation-time\">Monday</span>\n                        </div>\n                        <div class=\"last-message\">Can you review the document I shared?</div>\n                        <div class=\"conversation-bottom\">\n                            <span></span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"conversation-item\">\n                    <div class=\"avatar\">AG</div>\n                    <div class=\"conversation-content\">\n                        <div class=\"conversation-top\">\n                            <span class=\"contact-name\">Anna Garcia</span>\n                            <span class=\"conversation-time\">Sunday</span>\n                        </div>\n                        <div class=\"last-message\">Hope you have a wonderful weekend!</div>\n                        <div class=\"conversation-bottom\">\n                            <span></span>\n                            <span class=\"unread-badge\">3</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- RIGHT PANEL - Chat Thread -->\n        <div class=\"chat-panel\">\n            <div class=\"chat-header\">\n                <button class=\"back-button\">\u2190</button>\n                <div class=\"chat-avatar\">SM</div>\n                <div class=\"chat-contact-info\">\n                    <div class=\"chat-contact-name\">Sarah Miller</div>\n                    <div class=\"online-status\">\n                        <div class=\"online-dot\"></div>\n                        Online\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"messages-area\">\n                <div class=\"message incoming\">\n                    <div class=\"message-bubble\">\n                        Hey! How's your day going?\n                    </div>\n                    <div class=\"message-time\">1:45 PM</div>\n                </div>\n\n                <div class=\"message outgoing\">\n                    <div class=\"message-time\">1:47 PM</div>\n                    <div class=\"message-bubble\">\n                        Pretty good! Just finished up a big project. How about you?\n                    </div>\n                </div>\n\n                <div class=\"message incoming\">\n                    <div class=\"message-bubble\">\n                        That's awesome! I'm doing well, thanks for asking.\n                    </div>\n                    <div class=\"message-time\">1:48 PM</div>\n                </div>\n\n                <div class=\"message incoming\">\n                    <div class=\"message-bubble\">\n                        I wanted to ask you about lunch tomorrow. Are we still meeting at that new place downtown?\n                    </div>\n                    <div class=\"message-time\">1:49 PM</div>\n                </div>\n\n                <div class=\"message outgoing\">\n                    <div class=\"message-time\">1:52 PM</div>\n                    <div class=\"message-bubble\">\n                        Yes! I'm really looking forward to it. What time works best for you?\n                    </div>\n                </div>\n\n                <div class=\"message incoming\">\n                    <div class=\"message-bubble\">\n                        How about 12:30? That should give us plenty of time to catch up.\n                    </div>\n                    <div class=\"message-time\">1:53 PM</div>\n                </div>\n\n                <div class=\"message outgoing\">\n                    <div class=\"message-time\">1:55 PM</div>\n                    <div class=\"message-bubble\">\n                        Perfect! I'll see you there at 12:30. Can't wait to hear about your new job!\n                    </div>\n                </div>\n\n                <div class=\"message incoming\">\n                    <div class=\"message-bubble\">\n                        Hey! Are we still on for lunch tomorrow?\n                    </div>\n                    <div class=\"message-time\">2:34 PM</div>\n                </div>\n            </div>\n\n            <div class=\"composer\">\n                <textarea class=\"composer-input\" placeholder=\"Type a message...\" rows=\"1\"></textarea>\n                <button class=\"send-button\">\u2192</button>\n            </div>\n        </div>\n    </div>\n</body>\n</html>"}