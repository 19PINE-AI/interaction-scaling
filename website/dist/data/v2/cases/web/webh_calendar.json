today-button {\n            background: #10b981;\n            color: white;\n            border: none;\n            padding: 12px 24px;\n            border-radius: 12px;\n            font-size: 16px;\n            font-weight: 600;\n            cursor: pointer;\n            transition: background 0.2s;\n        }\n\n        .today-button:hover {\n            background: #059669;\n        }\n\n        /* Calendar Grid */\n        .calendar-grid {\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n        }\n\n        .calendar-header-row {\n            display: grid;\n            grid-template-columns: repeat(7, 1fr);\n            background: #f1f5f9;\n            border-bottom: 2px solid #e2e8f0;\n        }\n\n        .day-header {\n            padding: 20px;\n            text-align: center;\n            font-weight: 700;\n            font-size: 18px;\n            color: #475569;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        .calendar-body {\n            display: grid;\n            grid-template-columns: repeat(7, 1fr);\n            grid-template-rows: repeat(5, 1fr);\n        }\n\n        .day-cell {\n            min-height: 140px;\n            border-right: 1px solid #e2e8f0;\n            border-bottom: 1px solid #e2e8f0;\n            padding: 16px;\n            position: relative;\n            background: white;\n            transition: background 0.2s;\n        }\n\n        .day-cell:nth-child(7n) {\n            border-right: none;\n        }\n\n        .day-cell:hover {\n            background: #f8fafc;\n        }\n\n        .day-number {\n            font-size: 20px;\n            font-weight: 600;\n            color: #1e293b;\n            margin-bottom: 8px;\n        }\n\n        .day-cell.today .day-number {\n            background: #3b82f6;\n            color: white;\n            width: 32px;\n         