;\n            padding: 24px 20px 20px;\n            position: relative;\n            opacity: 0;\n            transition: opacity 0.3s ease;\n            overflow: hidden;\n        }\n\n        .gallery-item:hover .caption-overlay {\n            opacity: 1;\n        }\n\n        .caption-title {\n            font-size: 1.1rem;\n            font-weight: 600;\n            margin-bottom: 8px;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n        }\n\n        .caption-likes {\n            display: flex;\n            align-items: center;\n            gap: 6px;\n            font-size: 0.9rem;\n            opacity: 0.9;\n        }\n\n        .heart-icon {\n            width: 16px;\n            height: 16px;\n            fill: #ff6b6b;\n            flex-shrink: 0;\n        }\n\n        /* Load More Button */\n        .load-more-container {\n            text-align: center;\n            margin-bottom: 80px;\n        }\n\n        .load-more-btn {\n            background: #667eea;\n            color: white;\n            border: none;\n            border-radius: 50px;\n            padding: 16px 40px;\n            font-size: 1.1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);\n        }\n\n        .load-more-btn:hover {\n            background: #5a67d8;\n            transform: translateY(-2px);\n            box-shadow: 0 8px 30px rgba(102, 126, 234, 0.4);\n        }\n\n        /* Mobile Responsive */\n        @media (max-width: 375px) {\n            .container {\n                padding: 0 20px;\n            }\n\n            .header {\n                padding: 40px 0;\n                margin-bottom: 40px;\n            }\n\n            .header h1 {\n                font-size: 2.5rem;\n                letter-spacing: -1px;\n            }\n\n            .header p {\n                font-size: 1.1rem;\n            }\n\n            .filter-bar {\n                overflow-x: auto;\n                justify-content: flex-start;\n                padding: 0;\n                margin-bottom: 40px;\n                scrollbar-width: none;\n                -ms-overflow-style: none;\n                width: 100%;\n            }\n\n            .filter-bar::-webkit-scrollbar {\n                display: none;\n            }\n\n            .filter-pill {\n                flex-shrink: 0;\n                padding: 10px 16px;\n                font-size: 0.85rem;\n            }\n\n            .gallery {\n                grid-template-columns: 1fr;\n                gap: 20px;\n                margin-bottom: 60px;\n            }\n\n            .gallery-item:nth-child(n) .image-placeholder {\n                height: 280px;\n            }\n\n            .caption-title {\n                font-size: 1rem;\n            }\n\n            .caption-likes {\n                font-size: 0.85rem;\n            }\n\n            .load-more-container {\n                margin-bottom: 60px;\n            }\n\n            .load-more-btn {\n                padding: 14px 32px;\n                font-size: 1rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <header class=\"header\">\n        <div class=\"container\">\n            <h1>Shots</h1>\n            <p>Discover amazing photography from talented creators</p>\n        </div>\n    </header>\n\n    <main class=\"container\">\n        <div class=\"filter-bar\">\n            <button class=\"filter-pill active\">All</button>\n            <button class=\"filter-pill\">Nature</button>\n            <button class=\"filter-pill\">Urban</button>\n            <button class=\"filter-pill\">People</button>\n            <button class=\"filter-pill\">Art</button>\n        </div>\n\n        <div class=\"gallery\">\n            <div class=\"gallery-item\">\n                <div class=\"image-placeholder\">Mountain Sunrise</div>\n                <div class=\"capt