idth: 1920px;\n            margin: 0 auto;\n            padding: 0 40px;\n        }\n\n        /* Header */\n        .header {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            padding: 60px 0;\n            text-align: center;\n            margin-bottom: 60px;\n        }\n\n        .header h1 {\n            font-size: 4rem;\n            font-weight: 700;\n            letter-spacing: -2px;\n            margin-bottom: 16px;\n        }\n\n        .header p {\n            font-size: 1.25rem;\n            opacity: 0.9;\n            font-weight: 300;\n        }\n\n        /* Filter Bar */\n        .filter-bar {\n            display: flex;\n            justify-content: center;\n            gap: 16px;\n            margin-bottom: 60px;\n            padding: 0 20px;\n        }\n\n        .filter-pill {\n            background: white;\n            border: 2px solid #e0e0e0;\n            border-radius: 50px;\n            padding: 12px 24px;\n            font-size: 1rem;\n            font-weight: 500;\n            color: #666;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            white-space: nowrap;\n        }\n\n        .filter-pill.active {\n            background: #667eea;\n            border-color: #667eea;\n            color: white;\n            transform: translateY(-2px);\n            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);\n        }\n\n        .filter-pill:hover:not(.active) {\n            border-color: #667eea;\n            color: #667eea;\n            transform: translateY(-1px);\n        }\n\n        /* Gallery Grid */\n        .gallery {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 24px;\n            margin-bottom: 80px;\n        }\n\n        .gallery-item {\n            background: white;\n            border-radius: 16px;\n            overflow: hidden;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);\n