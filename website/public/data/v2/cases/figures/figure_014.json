      <!-- Heatmap values -->\n            <text x=\"1075\" y=\"250\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.1</text>\n            <text x=\"1125\" y=\"250\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.2</text>\n            <text x=\"1175\" y=\"250\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.3</text>\n            <text x=\"1225\" y=\"250\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.4</text>\n            \n            <text x=\"1075\" y=\"300\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.1</text>\n            <text x=\"1125\" y=\"300\" text-anchor=\"middle\" font-size=\"10\" fill=\"white\">0.6</text>\n            <text x=\"1175\" y=\"300\" text-anchor=\"middle\" font-size=\"10\" fill=\"white\">0.3</text>\n            <text x=\"1225\" y=\"300\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.0</text>\n            \n            <text x=\"1075\" y=\"350\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.0</text>\n            <text x=\"1125\" y=\"350\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.1</text>\n            <text x=\"1175\" y=\"350\" text-anchor=\"middle\" font-size=\"10\" fill=\"white\">0.7</text>\n            <text x=\"1225\" y=\"350\" text-anchor=\"middle\" font-size=\"10\" fill=\"white\">0.2</text>\n            \n            <text x=\"1075\" y=\"400\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.0</text>\n            <text x=\"1125\" y=\"400\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.0</text>\n            <text x=\"1175\" y=\"400\" text-anchor=\"middle\" font-size=\"10\" fill=\"#2c3e50\">0.2</text>\n            <text x=\"1225\" y=\"400\" text-anchor=\"middle\" font-size=\"10\" fill=\"white\">0.8</text>\n            \n            <!-- Axis labels -->\n            <text x=\"1020\" y=\"250\" text-anchor=\"middle\" font-size=\"12\" fill=\"#2c3e50\">the</text>\n            <text x=\"1020\" y=\"300\" text-anchor=\"