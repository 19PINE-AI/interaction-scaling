sition: transform 0.2s ease;\n        }\n\n        .card:hover {\n            transform: translateY(-2px);\n        }\n\n        .card-title {\n            font-size: 20px;\n            font-weight: 600;\n            color: #2c3e50;\n            margin-bottom: 12px;\n        }\n\n        .card-description {\n            font-size: 16px;\n            color: #7f8c8d;\n            line-height: 1.5;\n        }\n\n        .moving-card {\n            position: absolute;\n            width: 416px;\n            background: white;\n            border-radius: 12px;\n            padding: 24px;\n            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);\n            border-left: 6px solid #e74c3c;\n            z-index: 100;\n            transform: scale(1.05);\n            animation: slideCard 10.5s ease-in-out infinite;\n        }\n\n        @keyframes slideCard {\n            0% {\n                left: 172px;\n                top: 356px;\n            }\n            10% {\n                left: 172px;\n                top: 356px;\n            }\n            33.33% {\n                left: 702px;\n                top: 356px;\n            }\n            43.33% {\n                left: 702px;\n                top: 356px;\n            }\n            66.66% {\n                left: 1232px;\n                top: 356px;\n            }\n            76.66% {\n                left: 1232px;\n                top: 356px;\n            }\n            100% {\n                left: 172px;\n                top: 356px;\n            }\n        }\n\n        .moving-card .card-title {\n            color: #e74c3c;\n            font-weight: 700;\n        }\n\n        .board-title {\n            position: absolute;\n            top: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: white;\n            font-size: 48px;\n            font-weight: 800;\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);\n            letter-spacing: 2px;\n        }\n    </style