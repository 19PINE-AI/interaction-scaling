{"id": "anc_accordion", "modality": "animations", "name": "Accordion", "task": {"description": "Create a self-contained 1920x1080 HTML animation (inline CSS/JS, NO <canvas>) of a vertical accordion with FOUR equal-width section headers stacked in a centered column. Over ~3.5s, sections open one at a time: opening a section expands its content panel (pushing the sections below it down) while the previously-open section collapses. Headers stay equal-width and left/right aligned; expanded content stays inside its panel.", "requirements": ["Four equal-width section headers stay in one aligned vertical column at every frame", "Exactly one section's content panel is expanded at a time, and which one changes over time", "Expanded content stays inside its panel (no text overflow past the panel edges)", "Sections never overlap each other (the ones below shift down as a section expands)", "All sections stay fully within the viewport (the column does not push content off the bottom edge)", "Section headers remain equal-width and edge-aligned throughout"], "difficulty": "hard"}, "runs": [{"run": 1, "ss_n_defects": 47, "ss_text_overlap": null, "ss_clipped": null, "ss_overflow": null, "ss_total_tokens": 3033, "rv_n_defects": 12, "rv_text_overlap": null, "rv_clipped": null, "rv_overflow": null, "rv_iterations": 3, "rv_total_tokens": 17234}, {"run": 2, "ss_n_defects": 60, "ss_text_overlap": null, "ss_clipped": null, "ss_overflow": null, "ss_total_tokens": 3377, "rv_n_defects": 139, "rv_text_overlap": null, "rv_clipped": null, "rv_overflow": null, "rv_iterations": 3, "rv_total_tokens": 22778}, {"run": 3, "ss_n_defects": 60, "ss_text_overlap": null, "ss_clipped": null, "ss_overflow": null, "ss_total_tokens": 3262, "rv_n_defects": 7, "rv_text_overlap": null, "rv_clipped": null, "rv_overflow": null, "rv_iterations": 3, "rv_total_tokens": 16674}], "ss_img": "images/animations/anc_accordion_ss.jpg", "rv_img": "images/animations/anc_accordion_rv.jpg", "ss_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Vertical Accordion Animation</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: 1920px;\n            height: 1080px;\n            background: linear-gradient(135deg, #1e3c72, #2a5298);\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            overflow: hidden;\n        }\n\n        .accordion-container {\n            width: 800px;\n            background: rgba(255, 255, 255, 0.95);\n            border-radius: 16px;\n            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);\n            overflow: hidden;\n        }\n\n        .accordion-section {\n            border-bottom: 2px solid #e0e6ed;\n            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .accordion-section:last-child {\n            border-bottom: none;\n        }\n\n        .section-header {\n            width: 100%;\n            height: 80px;\n            background: linear-gradient(135deg, #667eea, #764ba2);\n            color: white;\n            border: none;\n            padding: 0 32px;\n            font-size: 24px;\n            font-weight: 600;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            transition: all 0.3s ease;\n            position: relative;\n            z-index: 2;\n        }\n\n        .section-header:hover {\n            background: linear-gradient(135deg, #5a6fd8, #6a4190);\n        }\n\n        .section-header.active {\n            background: linear-gradient(135deg, #ff6b6b, #ee5a24);\n        }\n\n        .header-icon {\n            width: 24px;\n            height: 24px;\n            transition: transform 0.3s ease;\n        }\n\n        .section-header.active .header-icon {\n            transform: rotate(180deg);\n        }\n\n        .section-content {\n            height: 0;\n            overflow: hidden;\n            background: white;\n            transition: height 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .section-content.active {\n            height: 200px;\n        }\n\n        .content-inner {\n            padding: 32px;\n            height: 200px;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n        }\n\n        .content-title {\n            font-size: 20px;\n            font-weight: 600;\n            color: #2c3e50;\n            margin-bottom: 16px;\n        }\n\n        .content-text {\n            font-size: 16px;\n            line-height: 1.6;\n            color: #5a6c7d;\n        }\n\n        /* Individual section styling */\n        .section-1 .section-header {\n            background: linear-gradient(135deg, #667eea, #764ba2);\n        }\n\n        .section-1 .section-header.active {\n            background: linear-gradient(135deg, #ff6b6b, #ee5a24);\n        }\n\n        .section-2 .section-header {\n            background: linear-gradient(135deg, #f093fb, #f5576c);\n        }\n\n        .section-2 .section-header.active {\n            background: linear-gradient(135deg, #4facfe, #00f2fe);\n        }\n\n        .section-3 .section-header {\n            background: linear-gradient(135deg, #43e97b, #38f9d7);\n        }\n\n        .section-3 .section-header.active {\n            background: linear-gradient(135deg, #fa709a, #fee140);\n        }\n\n        .section-4 .section-header {\n            background: linear-gradient(135deg, #fa709a, #fee140);\n        }\n\n        .section-4 .section-header.active {\n            background: linear-gradient(135deg, #a8edea, #fed6e3);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"accordion-container\">\n        <div class=\"accordion-section section-1\">\n            <button class=\"section-header\">\n                <span>Design Principles</span>\n                <svg class=\"header-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M7 10l5 5 5-5z\"/>\n                </svg>\n            </button>\n            <div class=\"section-content\">\n                <div class=\"content-inner\">\n                    <h3 class=\"content-title\">Core Design Fundamentals</h3>\n                    <p class=\"content-text\">Proximity, alignment, repetition, and contrast form the foundation of effective visual communication. These principles guide the eye and create hierarchy in design.</p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"accordion-section section-2\">\n            <button class=\"section-header\">\n                <span>Color Theory</span>\n                <svg class=\"header-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M7 10l5 5 5-5z\"/>\n                </svg>\n            </button>\n            <div class=\"section-content\">\n                <div class=\"content-inner\">\n                    <h3 class=\"content-title\">Harmonious Color Palettes</h3>\n                    <p class=\"content-text\">Understanding complementary, triadic, and analogous color relationships enables designers to create visually appealing and emotionally resonant compositions.</p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"accordion-section section-3\">\n            <button class=\"section-header\">\n                <span>Typography</span>\n                <svg class=\"header-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M7 10l5 5 5-5z\"/>\n                </svg>\n            </button>\n            <div class=\"section-content\">\n                <div class=\"content-inner\">\n                    <h3 class=\"content-title\">Readable & Expressive Text</h3>\n                    <p class=\"content-text\">Typography choices communicate tone and improve readability. Consistent font families, weights, and spacing create a unified visual system.</p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"accordion-section section-4\">\n            <button class=\"section-header\">\n                <span>Layout & Spacing</span>\n                <svg class=\"header-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M7 10l5 5 5-5z\"/>\n                </svg>\n            </button>\n            <div class=\"section-content\">\n                <div class=\"content-inner\">\n                    <h3 class=\"content-title\">Strategic White Space</h3>\n                    <p class=\"content-text\">Thoughtful spacing and layout create breathing room, establish relationships between elements, and guide users through the content naturally.</p>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        const sections = document.querySelectorAll('.accordion-section');\n        const headers = document.querySelectorAll('.section-header');\n        const contents = document.querySelectorAll('.section-content');\n\n        let currentActiveIndex = -1;\n        let animationStartTime = Date.now();\n\n        function openSection(index) {\n            // Close previously active section\n            if (currentActiveIndex !== -1) {\n                headers[currentActiveIndex].classList.remove('active');\n                contents[currentActiveIndex].classList.remove('active');\n            }\n\n            // Open new section\n            headers[index].classList.add('active');\n            contents[index].classList.add('active');\n            currentActiveIndex = index;\n        }\n\n        function startAnimation() {\n            const animationDuration = 3500; // 3.5 seconds\n            const sectionDelay = animationDuration / 4; // Each section gets equal time\n\n            // Open sections sequentially\n            sections.forEach((section, index) => {\n                setTimeout(() => {\n                    openSection(index);\n                }, index * sectionDelay);\n            });\n\n            // Restart animation after completion\n            setTimeout(() => {\n                // Close all sections\n                headers.forEach(header => header.classList.remove('active'));\n                contents.forEach(content => content.classList.remove('active'));\n                currentActiveIndex = -1;\n                \n                // Restart after a brief pause\n                setTimeout(startAnimation, 500);\n            }, animationDuration + 1000);\n        }\n\n        // Start the animation when page loads\n        window.addEventListener('load', () => {\n            setTimeout(startAnimation, 500);\n        });\n\n        // Add click functionality for manual interaction\n        headers.forEach((header, index) => {\n            header.addEventListener('click', () => {\n                if (currentActiveIndex === index) {\n                    // Close if clicking the active section\n                    header.classList.remove('active');\n                    contents[index].classList.remove('active');\n                    currentActiveIndex = -1;\n                } else {\n                    openSection(index);\n                }\n            });\n        });\n    </script>\n</body>\n</html>", "rv_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Vertical Accordion Animation</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: 1920px;\n            height: 1080px;\n            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            overflow: hidden;\n        }\n\n        .accordion-container {\n            width: 800px;\n            background: rgba(255, 255, 255, 0.95);\n            border-radius: 16px;\n            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);\n            overflow: hidden;\n        }\n\n        .accordion-section {\n            border-bottom: 2px solid #e0e6ed;\n            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .accordion-section:last-child {\n            border-bottom: none;\n        }\n\n        .section-header {\n            width: 100%;\n            height: 80px;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            border: none;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            padding: 0 32px;\n            font-size: 24px;\n            font-weight: 600;\n            letter-spacing: 0.5px;\n            transition: all 0.3s ease;\n            position: relative;\n            z-index: 10;\n        }\n\n        .section-header:hover {\n            background: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);\n            transform: translateY(-2px);\n            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);\n        }\n\n        .section-header.active {\n            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);\n        }\n\n        .header-icon {\n            width: 24px;\n            height: 24px;\n            transition: transform 0.3s ease;\n        }\n\n        .section-header.active .header-icon {\n            transform: rotate(180deg);\n        }\n\n        .section-content {\n            height: 0;\n            overflow: hidden;\n            background: white;\n            transition: height 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n            position: relative;\n            z-index: 1;\n        }\n\n        .section-content.active {\n            height: 120px;\n        }\n\n        .content-inner {\n            padding: 20px 32px;\n            height: 120px;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            overflow: hidden;\n        }\n\n        .content-title {\n            font-size: 18px;\n            font-weight: 700;\n            color: #2c3e50;\n            margin-bottom: 8px;\n            letter-spacing: 0.3px;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            line-height: 1.2;\n        }\n\n        .content-text {\n            font-size: 14px;\n            line-height: 1.4;\n            color: #5a6c7d;\n            font-weight: 400;\n            overflow: hidden;\n            display: -webkit-box;\n            -webkit-line-clamp: 2;\n            -webkit-box-orient: vertical;\n            max-height: 40px;\n        }\n\n        .content-highlight {\n            color: #ff6b6b;\n            font-weight: 600;\n        }\n\n        /* Animation keyframes for smooth transitions */\n        @keyframes slideDown {\n            from {\n                transform: translateY(-10px);\n                opacity: 0;\n            }\n            to {\n                transform: translateY(0);\n                opacity: 1;\n            }\n        }\n\n        .section-content.active .content-inner {\n            animation: slideDown 0.6s ease 0.2s both;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"accordion-container\">\n        <div class=\"accordion-section\" id=\"section1\">\n            <button class=\"section-header\">\n                <span>Design Principles</span>\n                <svg class=\"header-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M7 10l5 5 5-5z\"/>\n                </svg>\n            </button>\n            <div class=\"section-content\">\n                <div class=\"content-inner\">\n                    <h3 class=\"content-title\">Foundation of Great Design</h3>\n                    <p class=\"content-text\">\n                        Master the core principles of <span class=\"content-highlight\">proximity, alignment, repetition, and contrast</span> to create visually compelling designs.\n                    </p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"accordion-section\" id=\"section2\">\n            <button class=\"section-header\">\n                <span>Color Theory</span>\n                <svg class=\"header-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M7 10l5 5 5-5z\"/>\n                </svg>\n            </button>\n            <div class=\"section-content\">\n                <div class=\"content-inner\">\n                    <h3 class=\"content-title\">Harmonious Color Palettes</h3>\n                    <p class=\"content-text\">\n                        Explore <span class=\"content-highlight\">complementary, triadic, and analogous</span> color schemes to create emotional impact and readability.\n                    </p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"accordion-section\" id=\"section3\">\n            <button class=\"section-header\">\n                <span>Typography</span>\n                <svg class=\"header-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M7 10l5 5 5-5z\"/>\n                </svg>\n            </button>\n            <div class=\"section-content\">\n                <div class=\"content-inner\">\n                    <h3 class=\"content-title\">Expressive Type Systems</h3>\n                    <p class=\"content-text\">\n                        Build clear <span class=\"content-highlight\">visual hierarchy</span> through strategic font choices and spacing that guides readers naturally.\n                    </p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"accordion-section\" id=\"section4\">\n            <button class=\"section-header\">\n                <span>Layout & Composition</span>\n                <svg class=\"header-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M7 10l5 5 5-5z\"/>\n                </svg>\n            </button>\n            <div class=\"section-content\">\n                <div class=\"content-inner\">\n                    <h3 class=\"content-title\">Structured Visual Flow</h3>\n                    <p class=\"content-text\">\n                        Create <span class=\"content-highlight\">balanced compositions</span> using grids and whitespace to guide attention and enhance user experience.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let currentActiveSection = null;\n        let animationTimeout = null;\n\n        function activateSection(sectionId) {\n            // Deactivate current section\n            if (currentActiveSection) {\n                const currentHeader = currentActiveSection.querySelector('.section-header');\n                const currentContent = currentActiveSection.querySelector('.section-content');\n                \n                currentHeader.classList.remove('active');\n                currentContent.classList.remove('active');\n            }\n\n            // Activate new section\n            const newSection = document.getElementById(sectionId);\n            const newHeader = newSection.querySelector('.section-header');\n            const newContent = newSection.querySelector('.section-content');\n            \n            newHeader.classList.add('active');\n            newContent.classList.add('active');\n            \n            currentActiveSection = newSection;\n        }\n\n        function startAnimation() {\n            // Reset all sections\n            const sections = document.querySelectorAll('.accordion-section');\n            sections.forEach(section => {\n                const header = section.querySelector('.section-header');\n                const content = section.querySelector('.section-content');\n                header.classList.remove('active');\n                content.classList.remove('active');\n            });\n            currentActiveSection = null;\n\n            // Animation sequence: each section opens for ~875ms\n            const timings = [0, 875, 1750, 2625];\n            \n            timings.forEach((delay, index) => {\n                setTimeout(() => {\n                    activateSection(`section${index + 1}`);\n                }, delay);\n            });\n\n            // Loop the animation\n            animationTimeout = setTimeout(startAnimation, 3500);\n        }\n\n        // Start animation when page loads\n        window.addEventListener('load', () => {\n            setTimeout(startAnimation, 500);\n        });\n\n        // Add click handlers for manual interaction\n        document.querySelectorAll('.section-header').forEach((header, index) => {\n            header.addEventListener('click', () => {\n                // Clear automatic animation\n                if (animationTimeout) {\n                    clearTimeout(animationTimeout);\n                    animationTimeout = null;\n                }\n                \n                activateSection(`section${index + 1}`);\n            });\n        });\n    </script>\n</body>\n</html>"}