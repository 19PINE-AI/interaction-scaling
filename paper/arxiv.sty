% Minimal arxiv.sty — based on the popular community template
% Provides clean preprint-style layout suitable for arXiv submission.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{arxiv}[2024/01/01 arxiv style]

\RequirePackage{geometry}
\geometry{
  letterpaper,
  textwidth=6.5in,
  textheight=9in,
  marginparsep=7pt,
  marginparwidth=.6in,
  headheight=14pt,
  headsep=24pt,
  top=1in,
  bottom=1in,
}

\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhead{}
\fancyfoot{}
\fancyhead[L]{\itshape A Preprint}
\fancyhead[R]{\itshape \@runningtitle}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}

\newcommand{\@runningtitle}{}
\newcommand{\runningtitle}[1]{\renewcommand{\@runningtitle}{#1}}

% Title formatting
\renewcommand{\maketitle}{%
  \par
  \begingroup
  \def\and{\unskip\enspace{\rm and}\enspace}%
  \def\arabic{enumi}{}\def\@makefnmark{\rlap{\@textsuperscript{\normalfont\@thefnmark}}}%
  \long\def\@makefntext##1{\parindent 1em\noindent
            \hb@xt@1.8em{%
                \hss\@textsuperscript{\normalfont\@thefnmark}}##1}%
  \begin{center}%
    {\LARGE \bfseries \@title \par}%
    \vskip 1em%
    {\large
      \lineskip .5em%
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
    \vskip 1.5em%
  \end{center}%
  \par
  \endgroup
}

% Abstract environment
\renewenvironment{abstract}{%
  \vskip.075in%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}
}{%
  \par\end{quote}\vskip 1ex
}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\Large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\large\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\bfseries}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{*2}{*1.5}
\titlespacing*{\subsection}{0pt}{*1.5}{*1}

\endinput
