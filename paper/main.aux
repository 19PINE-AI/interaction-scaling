\@writefile{toc}{\contentsline {subsection}{\numberline {B.16}Original six-modality holistic overview (historical)}{26}{subsection.B.16}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Single-shot vs.\ reviewed quality across six modalities, Claude Sonnet 4 ($3$ runs, mean $\pm $ SD; code is a binary pass rate, other rows continuous in $[0,1]$; $p$ is a one-sided paired sign test on per-task means; \textbf  {bold} marks $p<0.05$). Code is scored by execution, video by the Gemini-native full-clip rubric, and the rest by a holistic screenshot judge. \emph  {This table is historical.} For the visual modalities it is superseded by the grounded measurements of \Cref  {sec:grounded_eval} (\Cref  {tab:geometric}), whose deterministic instrument sees the geometric defects the holistic judge cannot; those rows also use earlier, smaller task sets ($15$ web, $15$ animation, $20$ generic slides), hence the different $N$. Research here uses the old holistic judge ($0.63\to 0.69$), not the search-grounded factual rubric (single-shot $0.982$), so its gap reflects a change of instrument, not a contradiction; video uses the same rubric in both places ($0.70\to 0.74$).\relax }}{26}{table.caption.60}\protected@file@percent }
\newlabel{tab:harness-headline}{{17}{26}{Single-shot vs.\ reviewed quality across six modalities, Claude Sonnet 4 ($3$ runs, mean $\pm $ SD; code is a binary pass rate, other rows continuous in $[0,1]$; $p$ is a one-sided paired sign test on per-task means; \textbf {bold} marks $p<0.05$). Code is scored by execution, video by the Gemini-native full-clip rubric, and the rest by a holistic screenshot judge. \emph {This table is historical.} For the visual modalities it is superseded by the grounded measurements of \Cref {sec:grounded_eval} (\Cref {tab:geometric}), whose deterministic instrument sees the geometric defects the holistic judge cannot; those rows also use earlier, smaller task sets ($15$ web, $15$ animation, $20$ generic slides), hence the different $N$. Research here uses the old holistic judge ($0.63\to 0.69$), not the search-grounded factual rubric (single-shot $0.982$), so its gap reflects a change of instrument, not a contradiction; video uses the same rubric in both places ($0.70\to 0.74$).\relax }{table.caption.60}{}}
\newlabel{tab:harness-headline@cref}{{[table][17][2147483647]17}{[1][25][]26}}
