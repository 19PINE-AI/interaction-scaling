\@writefile{toc}{\contentsline {paragraph}{Cross-model, code.}{8}{paragraph*.25}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {An ungrounded reviewer makes layout worse (controlled ablation, two modalities).} Same tasks and proposer; only the reviewer's grounding varies. A VLM-feedback reviewer (\textsf  {VLM-fb}) \emph  {increases} mean geometric defects on both slides ($1.89\to 2.44$) and figures ($0.52\to 0.62$); the deterministic geometric-feedback reviewer (\textsf  {geom-fb}) reduces them ($1.25\to 0.33$; $0.57\to 0.15$). The grounded signal is necessary on the feedback side, not just the metric side.\relax }}{9}{figure.caption.23}\protected@file@percent }
\newlabel{fig:ablation}{{6}{9}{\textbf {An ungrounded reviewer makes layout worse (controlled ablation, two modalities).} Same tasks and proposer; only the reviewer's grounding varies. A VLM-feedback reviewer (\textsf {VLM-fb}) \emph {increases} mean geometric defects on both slides ($1.89\to 2.44$) and figures ($0.52\to 0.62$); the deterministic geometric-feedback reviewer (\textsf {geom-fb}) reduces them ($1.25\to 0.33$; $0.57\to 0.15$). The grounded signal is necessary on the feedback side, not just the metric side.\relax }{figure.caption.23}{}}
\newlabel{fig:ablation@cref}{{[figure][6][]6}{[1][8][]9}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {The execution-grounded loop helps every model family.} Single-shot vs.\ harness-reviewed code pass-rate for three model families ($+33.3$/$+26.7$/$+13.3$\,pp).\relax }}{9}{figure.caption.26}\protected@file@percent }
\newlabel{fig:crossmodel}{{7}{9}{\textbf {The execution-grounded loop helps every model family.} Single-shot vs.\ harness-reviewed code pass-rate for three model families ($+33.3$/$+26.7$/$+13.3$\,pp).\relax }{figure.caption.26}{}}
\newlabel{fig:crossmodel@cref}{{[figure][7][]7}{[1][9][]9}}
