\newlabel{sec:distill-ablation@cref}{{[subsection][5][7]7.5}{[1][22][]22}}
\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Consolidated SFT and post-training ablation on the 18-task hard held-out suite. All single-seed pass@1; pass@3 values are reported where collected. V3 with the 1500-character reasoning cap and 37 judge-kept teacher traces is the recipe sweet spot; V3+fc4k is identical in outcome quality but $2.2\times $ faster at inference. Configurations on either side of V3 are below the optimum and clarify which lever is load-bearing.\relax }}{22}{table.caption.50}\protected@file@percent }
\newlabel{tab:distill-ablation}{{17}{22}{Consolidated SFT and post-training ablation on the 18-task hard held-out suite. All single-seed pass@1; pass@3 values are reported where collected. V3 with the 1500-character reasoning cap and 37 judge-kept teacher traces is the recipe sweet spot; V3+fc4k is identical in outcome quality but $2.2\times $ faster at inference. Configurations on either side of V3 are below the optimum and clarify which lever is load-bearing.\relax }{table.caption.50}{}}
