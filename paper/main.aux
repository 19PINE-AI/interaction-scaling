\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Two axes saturate; the third does not.} At a matched $20$K-token budget on hard code, the two in-token-space axes (red) plateau below the interaction strategies (green), which all reach $\geq 97.8\%$. The proposer--reviewer harness reaches strict $100\%$ across seeds. Dotted line: best-of-$N$ ceiling.\relax }}{6}{figure.caption.12}\protected@file@percent }
\newlabel{fig:strategies}{{3}{6}{\textbf {Two axes saturate; the third does not.} At a matched $20$K-token budget on hard code, the two in-token-space axes (red) plateau below the interaction strategies (green), which all reach $\geq 97.8\%$. The proposer--reviewer harness reaches strict $100\%$ across seeds. Dotted line: best-of-$N$ ceiling.\relax }{figure.caption.12}{}}
\newlabel{fig:strategies@cref}{{[figure][3][]3}{[1][6][]6}}
