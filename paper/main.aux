\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces In-modality feedback-type controls on 15 hard code tasks (Sonnet 4 proposer and reviewer). Each row is a single on-policy seed; the ``SS'' column is the \emph  {per-seed} single-shot pass-rate (not held constant across rows) and ``Reviewed'' is the ceiling after that seed's harness run. The three SS values (10/15 and 11/15) are draws from the same single-shot distribution that gives \Cref  {tab:harness-headline}'s 3-run mean of $66.7 \pm 6.7$\% (i.e.\ within the $\pm 1$\,SD band centered on 10/15). Because the SS column varies by row, the load-bearing comparison is the \emph  {reviewed} ceiling: Type 3a reaches 14/15, Type 1/2 reach 13/15 ($+6.7$\,pp), \emph  {and} Type 3a is $\sim $2.5$\times $ more token-efficient (1.53 vs.\ 2.07 iterations).\relax }}{10}{table.caption.21}\protected@file@percent }
\newlabel{tab:type-controls}{{3}{10}{In-modality feedback-type controls on 15 hard code tasks (Sonnet 4 proposer and reviewer). Each row is a single on-policy seed; the ``SS'' column is the \emph {per-seed} single-shot pass-rate (not held constant across rows) and ``Reviewed'' is the ceiling after that seed's harness run. The three SS values (10/15 and 11/15) are draws from the same single-shot distribution that gives \Cref {tab:harness-headline}'s 3-run mean of $66.7 \pm 6.7$\% (i.e.\ within the $\pm 1$\,SD band centered on 10/15). Because the SS column varies by row, the load-bearing comparison is the \emph {reviewed} ceiling: Type 3a reaches 14/15, Type 1/2 reach 13/15 ($+6.7$\,pp), \emph {and} Type 3a is $\sim $2.5$\times $ more token-efficient (1.53 vs.\ 2.07 iterations).\relax }{table.caption.21}{}}
\newlabel{tab:type-controls@cref}{{[table][3][]3}{[1][10][]10}}
\@writefile{toc}{\contentsline {paragraph}{Type 3a beats the static channels on capability and efficiency, and Type 1 commits the predicted ungrounded-channel failure mode.}{11}{paragraph*.22}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Type 1 is stronger than naive ``no information'' would predict, and Type 1 $\approx $ Type 2 by construction of the bug set.}{11}{paragraph*.23}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Reasoning-only at matched budget: is this just more compute?}{11}{subsection.5.6}\protected@file@percent }
\newlabel{sec:harness-reasoning}{{5.6}{11}{Reasoning-only at matched budget: is this just more compute?}{subsection.5.6}{}}
\newlabel{sec:harness-reasoning@cref}{{[subsection][6][5]5.6}{[1][11][]11}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Reasoning-only at matched budget vs.\ single-shot and the harness on the 15 hard code tasks. Single-seed numbers (the Phase-1 reference seed, also used in \Cref  {tab:type-controls}); the 3-run aggregate is reported in \Cref  {tab:harness-headline} ($66.7 \pm 6.7$\% single-shot, $100.0 \pm 0.0$\% reviewed). Reasoning closes two-thirds of the harness's gap over single-shot but falls 6.7\,pp short of the harness's pass-rate even at $1.57\times $ the harness's token budget.\relax }}{11}{table.caption.24}\protected@file@percent }
\newlabel{tab:reasoning-baseline}{{4}{11}{Reasoning-only at matched budget vs.\ single-shot and the harness on the 15 hard code tasks. Single-seed numbers (the Phase-1 reference seed, also used in \Cref {tab:type-controls}); the 3-run aggregate is reported in \Cref {tab:harness-headline} ($66.7 \pm 6.7$\% single-shot, $100.0 \pm 0.0$\% reviewed). Reasoning closes two-thirds of the harness's gap over single-shot but falls 6.7\,pp short of the harness's pass-rate even at $1.57\times $ the harness's token budget.\relax }{table.caption.24}{}}
\newlabel{tab:reasoning-baseline@cref}{{[table][4][]4}{[1][11][]11}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {The headline scaling result (3-seed mean $\pm $ SD).} Pass-rate by strategy\nobreakspace  {}$\times $\nobreakspace  {}budget on 15 hard code tasks, Sonnet 4. S, L, and H are averaged over three independent on-policy runs; R was run once (extended-thinking variation across seeds is small at temp\nobreakspace  {}0) at the sweep's budget partition (a more generous partition lifts R to $86.7\%$; see footnote and \Cref  {tab:reasoning-baseline}). S's small dip from $B{=}1$K (80.0\%) to $B{=}5$K (77.8\%) is within the $\pm 3.1$\,pp seed noise on a 3-seed $\times $ 15-task suite; pass@$N$ is non-decreasing in $N$ in expectation but not pointwise across finite-sample on-policy seeds. \emph  {Reasoning-only and best-of-$N$ saturate well below 100\%}; all three iteration-with-feedback strategies reach $\geq 97.8\%$ at $B{=}20$K (L hit 100\% on 2 of 3 seeds; H on all 3; H is the only variant at strict 100\% across seeds). The architectural ordering across H, L is within seed noise on pass-rate; what separates them is token efficiency and reliability (\Cref  {sec:harness-separation}).\relax }}{12}{table.caption.25}\protected@file@percent }
\newlabel{tab:scaling-curves}{{5}{12}{\textbf {The headline scaling result (3-seed mean $\pm $ SD).} Pass-rate by strategy~$\times $~budget on 15 hard code tasks, Sonnet 4. S, L, and H are averaged over three independent on-policy runs; R was run once (extended-thinking variation across seeds is small at temp~0) at the sweep's budget partition (a more generous partition lifts R to $86.7\%$; see footnote and \Cref {tab:reasoning-baseline}). S's small dip from $B{=}1$K (80.0\%) to $B{=}5$K (77.8\%) is within the $\pm 3.1$\,pp seed noise on a 3-seed $\times $ 15-task suite; pass@$N$ is non-decreasing in $N$ in expectation but not pointwise across finite-sample on-policy seeds. \emph {Reasoning-only and best-of-$N$ saturate well below 100\%}; all three iteration-with-feedback strategies reach $\geq 97.8\%$ at $B{=}20$K (L hit 100\% on 2 of 3 seeds; H on all 3; H is the only variant at strict 100\% across seeds). The architectural ordering across H, L is within seed noise on pass-rate; what separates them is token efficiency and reliability (\Cref {sec:harness-separation}).\relax }{table.caption.25}{}}
\newlabel{tab:scaling-curves@cref}{{[table][5][]5}{[1][12][]12}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.7}Four-strategy scaling curves: the headline result}{12}{subsection.5.7}\protected@file@percent }
\newlabel{sec:harness-scaling}{{5.7}{12}{Four-strategy scaling curves: the headline result}{subsection.5.7}{}}
\newlabel{sec:harness-scaling@cref}{{[subsection][7][5]5.7}{[1][12][]12}}
\citation{ruan2025iad}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Four-strategy scaling curves on hard code (Sonnet 4, 3-seed means).} Reasoning-only (R) saturates at 73.3\% at this sweep's fixed thinking-to-output partition; a more generous thinking-heavy partition lifts R to 86.7\% (\Cref  {tab:reasoning-baseline}, shown by the dashed reference line). Best-of-$N$ at 86.7\%; both iteration-with-feedback strategies (L, H) reach the 100\% ceiling at $B{=}20$K within seed noise (L: 97.8\,$\pm $\,3.1\,pp; H: 100.0\,$\pm $\,0.0\,pp). The qualitative gap is between \emph  {reasoning/sampling} and \emph  {interaction with feedback}, not within the interaction strategies, and survives either R reading.\relax }}{13}{figure.caption.27}\protected@file@percent }
\newlabel{fig:scaling-curves}{{2}{13}{\textbf {Four-strategy scaling curves on hard code (Sonnet 4, 3-seed means).} Reasoning-only (R) saturates at 73.3\% at this sweep's fixed thinking-to-output partition; a more generous thinking-heavy partition lifts R to 86.7\% (\Cref {tab:reasoning-baseline}, shown by the dashed reference line). Best-of-$N$ at 86.7\%; both iteration-with-feedback strategies (L, H) reach the 100\% ceiling at $B{=}20$K within seed noise (L: 97.8\,$\pm $\,3.1\,pp; H: 100.0\,$\pm $\,0.0\,pp). The qualitative gap is between \emph {reasoning/sampling} and \emph {interaction with feedback}, not within the interaction strategies, and survives either R reading.\relax }{figure.caption.27}{}}
\newlabel{fig:scaling-curves@cref}{{[figure][2][]2}{[1][13][]13}}
