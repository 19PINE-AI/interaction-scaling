\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {The headline scaling result (3-seed mean $\pm $ SD).} Pass-rate by strategy\nobreakspace  {}$\times $\nobreakspace  {}budget on 15 hard code tasks, Sonnet 4. S, L, and H are averaged over three independent on-policy runs. R was run once (extended-thinking variation across seeds is small at temp\nobreakspace  {}0) at the sweep's budget partition (a more generous partition lifts R to $86.7\%$, see footnote and \Cref  {tab:reasoning-baseline}). S's small dip from $B{=}1$K (80.0\%) to $B{=}5$K (77.8\%) is within the $\pm 3.1$\,pp seed noise on a 3-seed $\times $ 15-task suite, since pass@$N$ is non-decreasing in $N$ in expectation but not pointwise across finite-sample on-policy seeds. \emph  {Reasoning-only and best-of-$N$ saturate well below 100\%}, while all three iteration-with-feedback strategies reach $\geq 97.8\%$ at $B{=}20$K (L hit 100\% on 2 of 3 seeds, H on all 3, so H is the only variant at strict 100\% across seeds). The architectural ordering across H, L is within seed noise on pass-rate. What separates them is token efficiency and reliability (\Cref  {sec:interaction}).\relax }}{19}{table.caption.47}\protected@file@percent }
\newlabel{tab:scaling-curves}{{3}{19}{\textbf {The headline scaling result (3-seed mean $\pm $ SD).} Pass-rate by strategy~$\times $~budget on 15 hard code tasks, Sonnet 4. S, L, and H are averaged over three independent on-policy runs. R was run once (extended-thinking variation across seeds is small at temp~0) at the sweep's budget partition (a more generous partition lifts R to $86.7\%$, see footnote and \Cref {tab:reasoning-baseline}). S's small dip from $B{=}1$K (80.0\%) to $B{=}5$K (77.8\%) is within the $\pm 3.1$\,pp seed noise on a 3-seed $\times $ 15-task suite, since pass@$N$ is non-decreasing in $N$ in expectation but not pointwise across finite-sample on-policy seeds. \emph {Reasoning-only and best-of-$N$ saturate well below 100\%}, while all three iteration-with-feedback strategies reach $\geq 97.8\%$ at $B{=}20$K (L hit 100\% on 2 of 3 seeds, H on all 3, so H is the only variant at strict 100\% across seeds). The architectural ordering across H, L is within seed noise on pass-rate. What separates them is token efficiency and reliability (\Cref {sec:interaction}).\relax }{table.caption.47}{}}
\newlabel{tab:scaling-curves@cref}{{[table][3][2147483647]3}{[1][18][]19}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Reasoning-only at matched budget vs.\ single-shot and the harness on the 15 hard code tasks. Single-seed numbers (the Phase-1 reference seed, also used in \Cref  {tab:type-controls}). The 3-run aggregate is reported in \Cref  {tab:harness-headline} ($66.7 \pm 6.7$\% single-shot, $100.0 \pm 0.0$\% reviewed). \emph  {Reading the numbers:} single-shot here is this single seed's $11/15=73.3\%$ (the canonical $3$-seed mean is $66.7\%$), and the reasoning value shown is the \emph  {thinking-heavy} partition ($86.7\%$). This coincides numerically with the oracle best-of-$N$ ceiling, while the \emph  {default}-partition reasoning ceiling ($73.3\%$, \Cref  {tab:scaling-curves}) coincides with this seed's single-shot. Both are coincidences of the small suite, not the same run. Reasoning closes two-thirds of the harness's gap over single-shot but falls 6.7\,pp short of the harness's pass-rate even at $1.57\times $ the harness's token budget.\relax }}{19}{table.caption.48}\protected@file@percent }
\newlabel{tab:reasoning-baseline}{{4}{19}{Reasoning-only at matched budget vs.\ single-shot and the harness on the 15 hard code tasks. Single-seed numbers (the Phase-1 reference seed, also used in \Cref {tab:type-controls}). The 3-run aggregate is reported in \Cref {tab:harness-headline} ($66.7 \pm 6.7$\% single-shot, $100.0 \pm 0.0$\% reviewed). \emph {Reading the numbers:} single-shot here is this single seed's $11/15=73.3\%$ (the canonical $3$-seed mean is $66.7\%$), and the reasoning value shown is the \emph {thinking-heavy} partition ($86.7\%$). This coincides numerically with the oracle best-of-$N$ ceiling, while the \emph {default}-partition reasoning ceiling ($73.3\%$, \Cref {tab:scaling-curves}) coincides with this seed's single-shot. Both are coincidences of the small suite, not the same run. Reasoning closes two-thirds of the harness's gap over single-shot but falls 6.7\,pp short of the harness's pass-rate even at $1.57\times $ the harness's token budget.\relax }{table.caption.48}{}}
\newlabel{tab:reasoning-baseline@cref}{{[table][4][2147483647]4}{[1][18][]19}}
