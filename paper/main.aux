\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Two axes saturate. The third does not.} The $20$K-token snapshot of \Cref  {fig:dpi}: the two in-token-space axes (red) plateau below the interaction strategies (green), which all reach $\geq 97.8\%$. Whiskers are $\pm 1$ SD over three seeds (reasoning was run once): the single-agent loop carries seed variance ($\pm 3.1$\,pp, $100\%$ in $2$ of $3$ seeds) while the proposer--reviewer harness reaches strict $100\%$ with \emph  {zero} seed variance. Dotted line: oracle best-of-$N$ ceiling.\relax }}{7}{figure.caption.12}\protected@file@percent }
\newlabel{fig:strategies}{{3}{7}{\textbf {Two axes saturate. The third does not.} The $20$K-token snapshot of \Cref {fig:dpi}: the two in-token-space axes (red) plateau below the interaction strategies (green), which all reach $\geq 97.8\%$. Whiskers are $\pm 1$ SD over three seeds (reasoning was run once): the single-agent loop carries seed variance ($\pm 3.1$\,pp, $100\%$ in $2$ of $3$ seeds) while the proposer--reviewer harness reaches strict $100\%$ with \emph {zero} seed variance. Dotted line: oracle best-of-$N$ ceiling.\relax }{figure.caption.12}{}}
\newlabel{fig:strategies@cref}{{[figure][3][]3}{[1][7][]7}}
