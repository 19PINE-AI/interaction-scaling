\@writefile{toc}{\contentsline {paragraph}{Architecture buys efficiency and reliability, not ceiling.}{8}{paragraph*.17}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Execution feedback recovers every first-shot failure on both code suites.} Single-shot vs.\ harness-reviewed pass rate (development suite: $3$-seed mean, whisker $\pm 1$\,SD; deep-spec: sign test $p=0.002$). Every failing run is recovered and no passing run regresses; the reviewed bars carry zero seed variance.\relax }}{9}{figure.caption.16}\protected@file@percent }
\newlabel{fig:code}{{6}{9}{\textbf {Execution feedback recovers every first-shot failure on both code suites.} Single-shot vs.\ harness-reviewed pass rate (development suite: $3$-seed mean, whisker $\pm 1$\,SD; deep-spec: sign test $p=0.002$). Every failing run is recovered and no passing run regresses; the reviewed bars carry zero seed variance.\relax }{figure.caption.16}{}}
\newlabel{fig:code@cref}{{[figure][6][]6}{[1][8][]9}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Same ceiling, different cost and reliability.} All three interaction strategies use execution feedback and tie on pass rate within seed noise (sign test $p>0.6$); the proposer--reviewer harness converges with ${\sim }28\%$ fewer tokens and is the only variant at $100\%$ across all seeds (\Cref  {tab:LvsH}).\relax }}{9}{figure.caption.18}\protected@file@percent }
\newlabel{fig:efficiency}{{7}{9}{\textbf {Same ceiling, different cost and reliability.} All three interaction strategies use execution feedback and tie on pass rate within seed noise (sign test $p>0.6$); the proposer--reviewer harness converges with ${\sim }28\%$ fewer tokens and is the only variant at $100\%$ across all seeds (\Cref {tab:LvsH}).\relax }{figure.caption.18}{}}
\newlabel{fig:efficiency@cref}{{[figure][7][]7}{[1][8][]9}}
