\@writefile{toc}{\contentsline {paragraph}{The default VLM judge is structurally blind.}{8}{paragraph*.17}\protected@file@percent }
\newlabel{fig:blind}{{4a}{9}{The VLM passes $14/15$, the deterministic instrument only $3/15$.\relax }{figure.caption.18}{}}
\newlabel{fig:blind@cref}{{[subfigure][1][4]4a}{[1][8][]9}}
\newlabel{sub@fig:blind}{{a}{9}{The VLM passes $14/15$, the deterministic instrument only $3/15$.\relax }{figure.caption.18}{}}
\newlabel{sub@fig:blind@cref}{{[subfigure][1][4]4a}{[1][8][]9}}
\newlabel{fig:evoformer}{{4b}{9}{A single-shot figure the VLM rated ``perfect'': both section titles are superimposed (``MSA Processing'' over ``MSA Representation''; ``Pair Processing'' over ``Pair Representation'') and axis labels collide with the matrix borders.\relax }{figure.caption.18}{}}
\newlabel{fig:evoformer@cref}{{[subfigure][2][4]4b}{[1][8][]9}}
\newlabel{sub@fig:evoformer}{{b}{9}{A single-shot figure the VLM rated ``perfect'': both section titles are superimposed (``MSA Processing'' over ``MSA Representation''; ``Pair Processing'' over ``Pair Representation'') and axis labels collide with the matrix borders.\relax }{figure.caption.18}{}}
\newlabel{sub@fig:evoformer@cref}{{[subfigure][2][4]4b}{[1][8][]9}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {The default VLM judge is structurally blind to layout defects.} \textbf  {(\subref  {fig:blind})} On the same $15$ single-shot academic figures, the VLM-on-a-screenshot judge rates $14$ ``perfect'' while the deterministic DOM-geometry instrument finds only $3$ actually clean. The other $11$ are broken in ways cropped off-frame or below VLM acuity. \textbf  {(\subref  {fig:evoformer})} A representative ``perfect''-rated render whose text-on-text overlaps ($\ge 6$\,px) are exactly what the geometry check flags and the screenshot judge misses.\relax }}{9}{figure.caption.18}\protected@file@percent }
\newlabel{fig:blindpair}{{4}{9}{\textbf {The default VLM judge is structurally blind to layout defects.} \textbf {(\subref {fig:blind})} On the same $15$ single-shot academic figures, the VLM-on-a-screenshot judge rates $14$ ``perfect'' while the deterministic DOM-geometry instrument finds only $3$ actually clean. The other $11$ are broken in ways cropped off-frame or below VLM acuity. \textbf {(\subref {fig:evoformer})} A representative ``perfect''-rated render whose text-on-text overlaps ($\ge 6$\,px) are exactly what the geometry check flags and the screenshot judge misses.\relax }{figure.caption.18}{}}
\newlabel{fig:blindpair@cref}{{[figure][4][]4}{[1][8][]9}}
\newlabel{fig:ba-ss}{{5a}{9}{\textbf {Single-shot.} Conditioning blocks crowd the down-block column, edges route through boxes and tangle at the center, and the legend collides with the decoder, all defects the geometry instrument flags but the VLM cannot see.\relax }{figure.caption.19}{}}
\newlabel{fig:ba-ss@cref}{{[subfigure][1][5]5a}{[1][8][]9}}
\newlabel{sub@fig:ba-ss}{{a}{9}{\textbf {Single-shot.} Conditioning blocks crowd the down-block column, edges route through boxes and tangle at the center, and the legend collides with the decoder, all defects the geometry instrument flags but the VLM cannot see.\relax }{figure.caption.19}{}}
\newlabel{sub@fig:ba-ss@cref}{{[subfigure][1][5]5a}{[1][8][]9}}
\newlabel{fig:ba-rv}{{5b}{9}{\textbf {After grounded feedback.} The same task: conditioning blocks lifted clear, columns spaced and aligned, skip connections deconflicted, legend boxed in free space.\relax }{figure.caption.19}{}}
\newlabel{fig:ba-rv@cref}{{[subfigure][2][5]5b}{[1][8][]9}}
\newlabel{sub@fig:ba-rv}{{b}{9}{\textbf {After grounded feedback.} The same task: conditioning blocks lifted clear, columns spaced and aligned, skip connections deconflicted, legend boxed in free space.\relax }{figure.caption.19}{}}
\newlabel{sub@fig:ba-rv@cref}{{[subfigure][2][5]5b}{[1][8][]9}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {What grounded geometric feedback actually fixes.} The same academic-figure task, single-shot (\subref  {fig:ba-ss}) vs.\ after the propose$\to $measure$\to $revise loop (\subref  {fig:ba-rv}). This is the per-artifact reality behind the $-74\%$ mean defect reduction in \Cref  {tab:geometric}, and exactly the difference a screenshot judge is blind to.\relax }}{9}{figure.caption.19}\protected@file@percent }
\newlabel{fig:beforeafter}{{5}{9}{\textbf {What grounded geometric feedback actually fixes.} The same academic-figure task, single-shot (\subref {fig:ba-ss}) vs.\ after the propose$\to $measure$\to $revise loop (\subref {fig:ba-rv}). This is the per-artifact reality behind the $-74\%$ mean defect reduction in \Cref {tab:geometric}, and exactly the difference a screenshot judge is blind to.\relax }{figure.caption.19}{}}
\newlabel{fig:beforeafter@cref}{{[figure][5][]5}{[1][8][]9}}
\@writefile{toc}{\contentsline {paragraph}{A deterministic instrument reveals a large, significant effect across four modalities.}{9}{paragraph*.20}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Deterministic geometric-feedback results, one identical configuration across four visual modalities (Sonnet\nobreakspace  {}4, $T{=}0$, $3$ seeds, alignment-inclusive reward). $\Delta $ is the mean defect reduction. CI is a paired bootstrap 95\% interval on $\Delta \%$ ($10$k resamples). $p$ is a two-sided paired sign test. Web is summed over $1920/375$ widths, animations over sampled frames.\relax }}{10}{table.caption.21}\protected@file@percent }
\newlabel{tab:geometric}{{2}{10}{Deterministic geometric-feedback results, one identical configuration across four visual modalities (Sonnet~4, $T{=}0$, $3$ seeds, alignment-inclusive reward). $\Delta $ is the mean defect reduction. CI is a paired bootstrap 95\% interval on $\Delta \%$ ($10$k resamples). $p$ is a two-sided paired sign test. Web is summed over $1920/375$ widths, animations over sampled frames.\relax }{table.caption.21}{}}
\newlabel{tab:geometric@cref}{{[table][2][]2}{[1][10][]10}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Grounded geometric feedback removes real layout defects on all four visual modalities} (mean reduction, with whiskers the paired-bootstrap 95\% CIs, all excluding zero). The standard VLM-on-a-screenshot metric measures none of this.\relax }}{10}{figure.caption.22}\protected@file@percent }
\newlabel{fig:geomreduction}{{6}{10}{\textbf {Grounded geometric feedback removes real layout defects on all four visual modalities} (mean reduction, with whiskers the paired-bootstrap 95\% CIs, all excluding zero). The standard VLM-on-a-screenshot metric measures none of this.\relax }{figure.caption.22}{}}
\newlabel{fig:geomreduction@cref}{{[figure][6][]6}{[1][10][]10}}
\@writefile{toc}{\contentsline {paragraph}{An ungrounded \emph  {reviewer} fails to fix layout, and on slides makes it worse (ablation, two modalities).}{10}{paragraph*.23}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Is the reduction circular?}{10}{paragraph*.25}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {An ungrounded reviewer fails to fix layout, while a grounded one does (controlled ablation, two modalities).} Same task suite and proposer model, with only the reviewer's grounding varying. The two arms are separate runs, so each is plotted against its \emph  {own} single-shot (hence the differing single-shot bars). The VLM-feedback reviewer (\textsf  {VLM-fb}) does not reduce defects and on slides increases them (slides $1.89\to 2.44$, figures $0.52\to 0.62$, directional/n.s.). The deterministic geometric-feedback reviewer (\textsf  {geom-fb}) reduces them (slides $1.25\to 0.33$, figures $0.57\to 0.15$). The grounded signal is necessary on the feedback side, not just the metric side.\relax }}{11}{figure.caption.24}\protected@file@percent }
\newlabel{fig:ablation}{{7}{11}{\textbf {An ungrounded reviewer fails to fix layout, while a grounded one does (controlled ablation, two modalities).} Same task suite and proposer model, with only the reviewer's grounding varying. The two arms are separate runs, so each is plotted against its \emph {own} single-shot (hence the differing single-shot bars). The VLM-feedback reviewer (\textsf {VLM-fb}) does not reduce defects and on slides increases them (slides $1.89\to 2.44$, figures $0.52\to 0.62$, directional/n.s.). The deterministic geometric-feedback reviewer (\textsf {geom-fb}) reduces them (slides $1.25\to 0.33$, figures $0.57\to 0.15$). The grounded signal is necessary on the feedback side, not just the metric side.\relax }{figure.caption.24}{}}
\newlabel{fig:ablation@cref}{{[figure][7][]7}{[1][10][]11}}
\@writefile{toc}{\contentsline {paragraph}{Two modalities where the honest answer is ``no headroom.''}{11}{paragraph*.26}\protected@file@percent }
