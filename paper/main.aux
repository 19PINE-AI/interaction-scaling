\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces \textbf  {The default VLM judge is structurally blind to layout defects.} \textbf  {(\subref  {fig:blind})} On the same $15$ single-shot academic figures, the VLM-on-a-screenshot judge rates $14$ ``perfect'' while the DOM-geometry instrument finds only $3$ actually clean; the other $11$ are broken in ways cropped off-frame or below VLM acuity. \textbf  {(\subref  {fig:evoformer})} A representative ``perfect''-rated render whose text-on-text overlaps are exactly what the geometry check flags and the screenshot judge misses.\relax }}{12}{figure.caption.28}\protected@file@percent }
\newlabel{fig:blindpair}{{11}{12}{\textbf {The default VLM judge is structurally blind to layout defects.} \textbf {(\subref {fig:blind})} On the same $15$ single-shot academic figures, the VLM-on-a-screenshot judge rates $14$ ``perfect'' while the DOM-geometry instrument finds only $3$ actually clean; the other $11$ are broken in ways cropped off-frame or below VLM acuity. \textbf {(\subref {fig:evoformer})} A representative ``perfect''-rated render whose text-on-text overlaps are exactly what the geometry check flags and the screenshot judge misses.\relax }{figure.caption.28}{}}
\newlabel{fig:blindpair@cref}{{[figure][11][]11}{[1][12][]12}}
\@writefile{toc}{\contentsline {paragraph}{A grounded instrument reveals a large, decisive effect on all four modalities.}{12}{paragraph*.29}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Is the reduction circular?}{12}{paragraph*.31}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \textbf  {Grounded geometric feedback removes real layout defects on all four visual modalities.} Mean defect reduction under one identical configuration ($3$ seeds; whiskers are paired-bootstrap 95\% CIs, all excluding zero; right column counts improved vs.\ regressed task-runs; all paired sign tests $p<2{\times }10^{-3}$; full statistics in \Cref  {tab:geometric}). The standard VLM-on-a-screenshot metric measures none of this.\relax }}{13}{figure.caption.30}\protected@file@percent }
\newlabel{fig:geomreduction}{{12}{13}{\textbf {Grounded geometric feedback removes real layout defects on all four visual modalities.} Mean defect reduction under one identical configuration ($3$ seeds; whiskers are paired-bootstrap 95\% CIs, all excluding zero; right column counts improved vs.\ regressed task-runs; all paired sign tests $p<2{\times }10^{-3}$; full statistics in \Cref {tab:geometric}). The standard VLM-on-a-screenshot metric measures none of this.\relax }{figure.caption.30}{}}
\newlabel{fig:geomreduction@cref}{{[figure][12][]12}{[1][12][]13}}
\@writefile{toc}{\contentsline {paragraph}{The geometry effect is not proposer-specific.}{13}{paragraph*.32}\protected@file@percent }
