\@writefile{toc}{\contentsline {paragraph}{Grounding is the variable, on both sides of the loop.}{2}{paragraph*.1}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Contributions.}{2}{paragraph*.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Grounding must hold on both sides of the interaction loop.} A proposer emits an artifact; an environment \emph  {executes/renders/measures} it and returns a grounded signal that the reviewer turns into a targeted revision. Grounded \emph  {feedback} (1) is what lets interaction import information from outside the weights and exceed the reasoning/sampling ceiling (\Cref  {sec:framework}). Grounded \emph  {evaluation} (2) is what makes the gain measurable: the default VLM-on-a-screenshot evaluator (red) is structurally blind to off-canvas overflow and fine overlap, so it neither measures nor (as a reviewer) fixes the defects.\relax }}{3}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:concept}{{1}{3}{\textbf {Grounding must hold on both sides of the interaction loop.} A proposer emits an artifact; an environment \emph {executes/renders/measures} it and returns a grounded signal that the reviewer turns into a targeted revision. Grounded \emph {feedback} (1) is what lets interaction import information from outside the weights and exceed the reasoning/sampling ceiling (\Cref {sec:framework}). Grounded \emph {evaluation} (2) is what makes the gain measurable: the default VLM-on-a-screenshot evaluator (red) is structurally blind to off-canvas overflow and fine overlap, so it neither measures nor (as a reviewer) fixes the defects.\relax }{figure.caption.2}{}}
\newlabel{fig:concept@cref}{{[figure][1][]1}{[1][2][]3}}
\@writefile{toc}{\contentsline {section}{\numberline {2}The Grounded-Feedback Framework}{3}{section.2}\protected@file@percent }
