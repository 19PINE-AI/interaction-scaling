\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Budget allocation simplex on 15 hard code tasks, $B = 10$K total. Pass-rate is monotone in the proposer's per-call cap, and review-heavy corners (low $b_1$) collapse. The 9-point sweep yields an 86.6\,pp spread.\relax }}{21}{table.caption.53}\protected@file@percent }
\newlabel{tab:allocation}{{9}{21}{Budget allocation simplex on 15 hard code tasks, $B = 10$K total. Pass-rate is monotone in the proposer's per-call cap, and review-heavy corners (low $b_1$) collapse. The 9-point sweep yields an 86.6\,pp spread.\relax }{table.caption.53}{}}
