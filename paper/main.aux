\newlabel{sec:feedback@cref}{{[section][5][]5}{[1][9][]9}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {The execution loop replicates across model families.} Single-shot vs.\ harness-reviewed code pass rate for three families, three seeds each (lifts $+33.3$/$+22.2$/$+20.0$\,pp; whiskers $\pm 1$\,SD across seeds). The reviewed bars carry \emph  {zero} seed variance for all three families.\relax }}{10}{figure.caption.21}\protected@file@percent }
\newlabel{fig:crossmodel-code}{{8}{10}{\textbf {The execution loop replicates across model families.} Single-shot vs.\ harness-reviewed code pass rate for three families, three seeds each (lifts $+33.3$/$+22.2$/$+20.0$\,pp; whiskers $\pm 1$\,SD across seeds). The reviewed bars carry \emph {zero} seed variance for all three families.\relax }{figure.caption.21}{}}
\newlabel{fig:crossmodel-code@cref}{{[figure][8][]8}{[1][9][]10}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {Swapping only the feedback signal on a fixed code suite: improvement tracks coverage, and cost tracks it decisively.} One reviewing pass per configuration. Ungrounded critique (orange), critique + linter (light blue: grounded, but observing only \emph  {form}), and critique + test execution (blue: grounded, observing \emph  {behavior}). The linter configuration matches bare critique on these runtime-logic bugs (exactly what the coverage principle predicts) while the execution configuration reaches a higher ceiling at ${\sim }2.5\times $ lower cost and fewer iterations ($1.53$ vs.\ $2.07$; per-seed detail in \Cref  {tab:type-controls}).\relax }}{10}{figure.caption.23}\protected@file@percent }
\newlabel{fig:typecontrol}{{9}{10}{\textbf {Swapping only the feedback signal on a fixed code suite: improvement tracks coverage, and cost tracks it decisively.} One reviewing pass per configuration. Ungrounded critique (orange), critique + linter (light blue: grounded, but observing only \emph {form}), and critique + test execution (blue: grounded, observing \emph {behavior}). The linter configuration matches bare critique on these runtime-logic bugs (exactly what the coverage principle predicts) while the execution configuration reaches a higher ceiling at ${\sim }2.5\times $ lower cost and fewer iterations ($1.53$ vs.\ $2.07$; per-seed detail in \Cref {tab:type-controls}).\relax }{figure.caption.23}{}}
\newlabel{fig:typecontrol@cref}{{[figure][9][]9}{[1][10][]10}}
\@writefile{toc}{\contentsline {paragraph}{On code: execution feedback wins where its coverage lies.}{10}{paragraph*.22}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {Same tasks, same proposer, one reviewing pass: the arrow's direction is set by the reviewer's instrument.} Each arrow runs from that configuration's own single-shot baseline (open circle; the configurations are separate runs, hence differing baselines) to its reviewed result, in mean geometric defects per artifact (lower is better; note the differing $y$ scales). The screenshot-fed VLM reviewer moves \emph  {up} on slides and directionally up on figures; the deterministic geometric reviewer moves sharply \emph  {down} on both (slides $-73\%$, $p=0.0018$; figures $-74\%$, $p=7{\times }10^{-4}$).\relax }}{11}{figure.caption.25}\protected@file@percent }
\newlabel{fig:ablation}{{10}{11}{\textbf {Same tasks, same proposer, one reviewing pass: the arrow's direction is set by the reviewer's instrument.} Each arrow runs from that configuration's own single-shot baseline (open circle; the configurations are separate runs, hence differing baselines) to its reviewed result, in mean geometric defects per artifact (lower is better; note the differing $y$ scales). The screenshot-fed VLM reviewer moves \emph {up} on slides and directionally up on figures; the deterministic geometric reviewer moves sharply \emph {down} on both (slides $-73\%$, $p=0.0018$; figures $-74\%$, $p=7{\times }10^{-4}$).\relax }{figure.caption.25}{}}
\newlabel{fig:ablation@cref}{{[figure][10][]10}{[1][11][]11}}
