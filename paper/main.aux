\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Reasoning-only at matched budget vs.\ single-shot and the harness on the 15 hard code tasks. Single-seed numbers (the Phase-1 reference seed, also used in \Cref  {tab:type-controls}); the 3-run aggregate is reported in \Cref  {tab:harness-headline} ($66.7 \pm 6.7$\% single-shot, $100.0 \pm 0.0$\% reviewed). \emph  {Reading the numbers:} single-shot here is this single seed's $11/15=73.3\%$ (the canonical $3$-seed mean is $66.7\%$), and the reasoning value shown is the \emph  {thinking-heavy} partition ($86.7\%$); this coincides numerically with the oracle best-of-$N$ ceiling, while the \emph  {default}-partition reasoning ceiling ($73.3\%$, \Cref  {tab:scaling-curves}) coincides with this seed's single-shot---both are coincidences of the small suite, not the same run. Reasoning closes two-thirds of the harness's gap over single-shot but falls 6.7\,pp short of the harness's pass-rate even at $1.57\times $ the harness's token budget.\relax }}{17}{table.caption.47}\protected@file@percent }
\newlabel{tab:reasoning-baseline}{{4}{17}{Reasoning-only at matched budget vs.\ single-shot and the harness on the 15 hard code tasks. Single-seed numbers (the Phase-1 reference seed, also used in \Cref {tab:type-controls}); the 3-run aggregate is reported in \Cref {tab:harness-headline} ($66.7 \pm 6.7$\% single-shot, $100.0 \pm 0.0$\% reviewed). \emph {Reading the numbers:} single-shot here is this single seed's $11/15=73.3\%$ (the canonical $3$-seed mean is $66.7\%$), and the reasoning value shown is the \emph {thinking-heavy} partition ($86.7\%$); this coincides numerically with the oracle best-of-$N$ ceiling, while the \emph {default}-partition reasoning ceiling ($73.3\%$, \Cref {tab:scaling-curves}) coincides with this seed's single-shot---both are coincidences of the small suite, not the same run. Reasoning closes two-thirds of the harness's gap over single-shot but falls 6.7\,pp short of the harness's pass-rate even at $1.57\times $ the harness's token budget.\relax }{table.caption.47}{}}
\newlabel{tab:reasoning-baseline@cref}{{[table][4][2147483647]4}{[1][16][]17}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces In-modality feedback-type controls on 15 hard code tasks (Sonnet 4 proposer and reviewer). Each row is a single on-policy seed; the ``SS'' column is the \emph  {per-seed} single-shot pass-rate (not held constant across rows) and ``Reviewed'' is the ceiling after that seed's harness run. The three SS values (10/15 and 11/15) are draws from the same single-shot distribution that gives \Cref  {tab:harness-headline}'s 3-run mean of $66.7 \pm 6.7$\% (i.e.\ within the $\pm 1$\,SD band centered on 10/15). Because the SS column varies by row, the load-bearing comparison is the \emph  {reviewed} ceiling: Type 3a reaches 14/15, Type 1/2 reach 13/15 ($+6.7$\,pp), \emph  {and} Type 3a is $\sim $2.5$\times $ more token-efficient ($2{,}643$ vs.\ ${\sim }7{,}100$ tokens/task; 1.53 vs.\ 2.07 iterations). The single task unrecovered in every control row is \texttt  {code\_011} (CJK text wrapping); the full harness at $B{=}20$K recovers it across all three seeds (\Cref  {tab:scaling-curves}), which is why the headline reviewed rate is the strict $100\%$ of \Cref  {tab:harness-headline} while this leaner single-seed control caps at $14/15$.\relax }}{17}{table.caption.48}\protected@file@percent }
\newlabel{tab:type-controls}{{5}{17}{In-modality feedback-type controls on 15 hard code tasks (Sonnet 4 proposer and reviewer). Each row is a single on-policy seed; the ``SS'' column is the \emph {per-seed} single-shot pass-rate (not held constant across rows) and ``Reviewed'' is the ceiling after that seed's harness run. The three SS values (10/15 and 11/15) are draws from the same single-shot distribution that gives \Cref {tab:harness-headline}'s 3-run mean of $66.7 \pm 6.7$\% (i.e.\ within the $\pm 1$\,SD band centered on 10/15). Because the SS column varies by row, the load-bearing comparison is the \emph {reviewed} ceiling: Type 3a reaches 14/15, Type 1/2 reach 13/15 ($+6.7$\,pp), \emph {and} Type 3a is $\sim $2.5$\times $ more token-efficient ($2{,}643$ vs.\ ${\sim }7{,}100$ tokens/task; 1.53 vs.\ 2.07 iterations). The single task unrecovered in every control row is \texttt {code\_011} (CJK text wrapping); the full harness at $B{=}20$K recovers it across all three seeds (\Cref {tab:scaling-curves}), which is why the headline reviewed rate is the strict $100\%$ of \Cref {tab:harness-headline} while this leaner single-seed control caps at $14/15$.\relax }{table.caption.48}{}}
\newlabel{tab:type-controls@cref}{{[table][5][2147483647]5}{[1][16][]17}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Three interaction-strategy variants at $B{=}20$K on the 15 hard code tasks, all using Type 3a execution feedback. Pass-rate is within seed noise (sign-test $p{>}0.6$ on the H--L comparison); the harness wins on \emph  {token efficiency} (1{,}029 vs.\ 1{,}431 L vs.\ 1{,}416 IAD mean output tokens) and on \emph  {seed variance} (zero across three seeds for H; L hit 100\% in 2 of 3 seeds; IAD was run for one seed only).\relax }}{18}{table.caption.49}\protected@file@percent }
\newlabel{tab:LvsH}{{6}{18}{Three interaction-strategy variants at $B{=}20$K on the 15 hard code tasks, all using Type 3a execution feedback. Pass-rate is within seed noise (sign-test $p{>}0.6$ on the H--L comparison); the harness wins on \emph {token efficiency} (1{,}029 vs.\ 1{,}431 L vs.\ 1{,}416 IAD mean output tokens) and on \emph {seed variance} (zero across three seeds for H; L hit 100\% in 2 of 3 seeds; IAD was run for one seed only).\relax }{table.caption.49}{}}
\newlabel{tab:LvsH@cref}{{[table][6][2147483647]6}{[1][16][]18}}
