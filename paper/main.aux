\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces In-modality feedback-type controls on 15 hard code tasks (Sonnet 4 proposer and reviewer). Each row is a single on-policy seed. The ``SS'' column is the \emph  {per-seed} single-shot pass-rate (not held constant across rows) and ``Reviewed'' is the ceiling after that seed's harness run. The three SS values (10/15 and 11/15) are draws from the same single-shot distribution that gives \Cref  {tab:harness-headline}'s 3-run mean of $66.7 \pm 6.7$\% (i.e.\ within the $\pm 1$\,SD band centered on 10/15). Because the SS column varies by row, the load-bearing comparison is the \emph  {reviewed} ceiling: Type 3a reaches 14/15, Type 1/2 reach 13/15 ($+6.7$\,pp), \emph  {and} Type 3a is $\sim $2.5$\times $ more token-efficient ($2{,}643$ vs.\ ${\sim }7{,}100$ tokens/task, 1.53 vs.\ 2.07 iterations). The single task unrecovered in every control row is \texttt  {code\_011} (CJK text wrapping). The full harness at $B{=}20$K recovers it across all three seeds (\Cref  {tab:scaling-curves}), which is why the headline reviewed rate is the strict $100\%$ of \Cref  {tab:harness-headline} while this leaner single-seed control caps at $14/15$.\relax }}{20}{table.caption.49}\protected@file@percent }
\newlabel{tab:type-controls}{{5}{20}{In-modality feedback-type controls on 15 hard code tasks (Sonnet 4 proposer and reviewer). Each row is a single on-policy seed. The ``SS'' column is the \emph {per-seed} single-shot pass-rate (not held constant across rows) and ``Reviewed'' is the ceiling after that seed's harness run. The three SS values (10/15 and 11/15) are draws from the same single-shot distribution that gives \Cref {tab:harness-headline}'s 3-run mean of $66.7 \pm 6.7$\% (i.e.\ within the $\pm 1$\,SD band centered on 10/15). Because the SS column varies by row, the load-bearing comparison is the \emph {reviewed} ceiling: Type 3a reaches 14/15, Type 1/2 reach 13/15 ($+6.7$\,pp), \emph {and} Type 3a is $\sim $2.5$\times $ more token-efficient ($2{,}643$ vs.\ ${\sim }7{,}100$ tokens/task, 1.53 vs.\ 2.07 iterations). The single task unrecovered in every control row is \texttt {code\_011} (CJK text wrapping). The full harness at $B{=}20$K recovers it across all three seeds (\Cref {tab:scaling-curves}), which is why the headline reviewed rate is the strict $100\%$ of \Cref {tab:harness-headline} while this leaner single-seed control caps at $14/15$.\relax }{table.caption.49}{}}
\newlabel{tab:type-controls@cref}{{[table][5][2147483647]5}{[1][18][]20}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Three interaction-strategy variants at $B{=}20$K on the 15 hard code tasks, all using Type 3a execution feedback. Pass-rate is within seed noise (sign-test $p{>}0.6$ on the H--L comparison). The harness wins on \emph  {token efficiency} (1{,}029 vs.\ 1{,}431 L vs.\ 1{,}416 IAD mean output tokens) and on \emph  {seed variance} (zero across three seeds for H, while L hit 100\% in 2 of 3 seeds and IAD was run for one seed only).\relax }}{20}{table.caption.50}\protected@file@percent }
\newlabel{tab:LvsH}{{6}{20}{Three interaction-strategy variants at $B{=}20$K on the 15 hard code tasks, all using Type 3a execution feedback. Pass-rate is within seed noise (sign-test $p{>}0.6$ on the H--L comparison). The harness wins on \emph {token efficiency} (1{,}029 vs.\ 1{,}431 L vs.\ 1{,}416 IAD mean output tokens) and on \emph {seed variance} (zero across three seeds for H, while L hit 100\% in 2 of 3 seeds and IAD was run for one seed only).\relax }{table.caption.50}{}}
\newlabel{tab:LvsH@cref}{{[table][6][2147483647]6}{[1][18][]20}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Cross-model replication on the same 15 hard code tasks, each family over \emph  {three} independent on-policy seeds at $T{=}0.7$ (Claude is the multi-run reference from \Cref  {tab:harness-headline}). The reviewed ceiling has zero seed variance for all three families, and the harness lift survives across Anthropic, Alibaba, and OpenAI. Single-shot per-seed pass-rates: Qwen $66.7/73.3/73.3\%$, GPT-5 $86.7/80.0/73.3\%$.\relax }}{20}{table.caption.51}\protected@file@percent }
\newlabel{tab:crossmodel}{{7}{20}{Cross-model replication on the same 15 hard code tasks, each family over \emph {three} independent on-policy seeds at $T{=}0.7$ (Claude is the multi-run reference from \Cref {tab:harness-headline}). The reviewed ceiling has zero seed variance for all three families, and the harness lift survives across Anthropic, Alibaba, and OpenAI. Single-shot per-seed pass-rates: Qwen $66.7/73.3/73.3\%$, GPT-5 $86.7/80.0/73.3\%$.\relax }{table.caption.51}{}}
\newlabel{tab:crossmodel@cref}{{[table][7][2147483647]7}{[1][18][]20}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Held-out generalization on 32 newly constructed code tasks (zero overlap with the 15-task development set). The harness recovers 3/3 single-shot failures and regresses zero passing tasks. The smaller absolute $\Delta $ is a baseline-compression effect (single-shot is 90.6\% on the held-out set, leaving at most 9.4\,pp headroom).\relax }}{20}{table.caption.52}\protected@file@percent }
\newlabel{tab:heldout}{{8}{20}{Held-out generalization on 32 newly constructed code tasks (zero overlap with the 15-task development set). The harness recovers 3/3 single-shot failures and regresses zero passing tasks. The smaller absolute $\Delta $ is a baseline-compression effect (single-shot is 90.6\% on the held-out set, leaving at most 9.4\,pp headroom).\relax }{table.caption.52}{}}
