\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Reasoning-only at matched budget vs.\ single-shot and the harness on the 15 hard code tasks. Single-seed numbers (the Phase-1 reference seed, also used in \Cref  {tab:type-controls}); the 3-run aggregate is reported in \Cref  {tab:harness-headline} ($66.7 \pm 6.7$\% single-shot, $100.0 \pm 0.0$\% reviewed). Reasoning closes two-thirds of the harness's gap over single-shot but falls 6.7\,pp short of the harness's pass-rate even at $1.57\times $ the harness's token budget.\relax }}{13}{table.caption.38}\protected@file@percent }
\newlabel{tab:reasoning-baseline}{{4}{13}{Reasoning-only at matched budget vs.\ single-shot and the harness on the 15 hard code tasks. Single-seed numbers (the Phase-1 reference seed, also used in \Cref {tab:type-controls}); the 3-run aggregate is reported in \Cref {tab:harness-headline} ($66.7 \pm 6.7$\% single-shot, $100.0 \pm 0.0$\% reviewed). Reasoning closes two-thirds of the harness's gap over single-shot but falls 6.7\,pp short of the harness's pass-rate even at $1.57\times $ the harness's token budget.\relax }{table.caption.38}{}}
\newlabel{tab:reasoning-baseline@cref}{{[table][4][2147483647]4}{[1][12][]13}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces In-modality feedback-type controls on 15 hard code tasks (Sonnet 4 proposer and reviewer). Each row is a single on-policy seed; the ``SS'' column is the \emph  {per-seed} single-shot pass-rate (not held constant across rows) and ``Reviewed'' is the ceiling after that seed's harness run. The three SS values (10/15 and 11/15) are draws from the same single-shot distribution that gives \Cref  {tab:harness-headline}'s 3-run mean of $66.7 \pm 6.7$\% (i.e.\ within the $\pm 1$\,SD band centered on 10/15). Because the SS column varies by row, the load-bearing comparison is the \emph  {reviewed} ceiling: Type 3a reaches 14/15, Type 1/2 reach 13/15 ($+6.7$\,pp), \emph  {and} Type 3a is $\sim $2.5$\times $ more token-efficient (1.53 vs.\ 2.07 iterations).\relax }}{13}{table.caption.39}\protected@file@percent }
\newlabel{tab:type-controls}{{5}{13}{In-modality feedback-type controls on 15 hard code tasks (Sonnet 4 proposer and reviewer). Each row is a single on-policy seed; the ``SS'' column is the \emph {per-seed} single-shot pass-rate (not held constant across rows) and ``Reviewed'' is the ceiling after that seed's harness run. The three SS values (10/15 and 11/15) are draws from the same single-shot distribution that gives \Cref {tab:harness-headline}'s 3-run mean of $66.7 \pm 6.7$\% (i.e.\ within the $\pm 1$\,SD band centered on 10/15). Because the SS column varies by row, the load-bearing comparison is the \emph {reviewed} ceiling: Type 3a reaches 14/15, Type 1/2 reach 13/15 ($+6.7$\,pp), \emph {and} Type 3a is $\sim $2.5$\times $ more token-efficient (1.53 vs.\ 2.07 iterations).\relax }{table.caption.39}{}}
\newlabel{tab:type-controls@cref}{{[table][5][2147483647]5}{[1][12][]13}}
