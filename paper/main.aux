\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Grounding must hold on both sides of the interaction loop.} A proposer emits an artifact; a grounded environment \emph  {executes/renders/measures} it, and that same observation does double duty: \textbf  {(1)} as grounded \emph  {feedback}, it becomes a defect list the reviewer turns into a targeted revision---the channel that lets interaction import information from outside the weights and exceed the reasoning/sampling ceiling (\Cref  {sec:framework}); \textbf  {(2)} as grounded \emph  {evaluation}, it is the score that makes the gain measurable. Substituting the default VLM-on-a-screenshot judge (red lane) breaks \emph  {both}: it is structurally blind to off-canvas overflow and fine overlap, so it neither scores the defect nor (as a reviewer) fixes it.\relax }}{3}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:concept}{{1}{3}{\textbf {Grounding must hold on both sides of the interaction loop.} A proposer emits an artifact; a grounded environment \emph {executes/renders/measures} it, and that same observation does double duty: \textbf {(1)} as grounded \emph {feedback}, it becomes a defect list the reviewer turns into a targeted revision---the channel that lets interaction import information from outside the weights and exceed the reasoning/sampling ceiling (\Cref {sec:framework}); \textbf {(2)} as grounded \emph {evaluation}, it is the score that makes the gain measurable. Substituting the default VLM-on-a-screenshot judge (red lane) breaks \emph {both}: it is structurally blind to off-canvas overflow and fine overlap, so it neither scores the defect nor (as a reviewer) fixes it.\relax }{figure.caption.2}{}}
\newlabel{fig:concept@cref}{{[figure][1][]1}{[1][2][]3}}
