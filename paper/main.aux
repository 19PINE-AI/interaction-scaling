\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}A feedback taxonomy by grounding}{3}{subsection.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {The DPI ceiling.} Reasoning and best-of-$N$ are functions of the frozen weights/prompt $(\Theta ,X)$ and saturate at the information already present (measured $73.3\%$ and $86.7\%$ on hard code at a $20$K-token budget; \Cref  {sec:interaction}). Grounded interaction imports external information each cycle and exceeds the ceiling, reaching strict $100\%$. Schematic; saturation values are the measured ceilings.\relax }}{4}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dpi}{{2}{4}{\textbf {The DPI ceiling.} Reasoning and best-of-$N$ are functions of the frozen weights/prompt $(\Theta ,X)$ and saturate at the information already present (measured $73.3\%$ and $86.7\%$ on hard code at a $20$K-token budget; \Cref {sec:interaction}). Grounded interaction imports external information each cycle and exceeds the ceiling, reaching strict $100\%$. Schematic; saturation values are the measured ceilings.\relax }{figure.caption.6}{}}
\newlabel{fig:dpi@cref}{{[figure][2][]2}{[1][4][]4}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Why grounding breaks the ceiling: a DPI bound}{4}{subsection.2.2}\protected@file@percent }
