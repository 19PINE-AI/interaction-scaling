\@writefile{toc}{\contentsline {paragraph}{Grounding is the variable, on both sides of the loop.}{2}{paragraph*.1}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Contributions.}{2}{paragraph*.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Grounding must hold on both sides of the interaction loop.} A proposer emits an artifact, and a grounded environment \emph  {executes/renders/measures} it. That same observation does double duty. \textbf  {(1)} As grounded \emph  {feedback}, it becomes a defect list the reviewer turns into a targeted revision, the channel that lets interaction import information from outside the weights and exceed the reasoning/sampling ceiling (\Cref  {sec:framework}). \textbf  {(2)} As grounded \emph  {evaluation}, it is the score that makes the gain measurable. Substituting the default VLM-on-a-screenshot judge (red lane) breaks \emph  {both}: it is structurally blind to off-canvas overflow and fine overlap, so it neither scores the defect nor (as a reviewer) fixes it.\relax }}{3}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:concept}{{1}{3}{\textbf {Grounding must hold on both sides of the interaction loop.} A proposer emits an artifact, and a grounded environment \emph {executes/renders/measures} it. That same observation does double duty. \textbf {(1)} As grounded \emph {feedback}, it becomes a defect list the reviewer turns into a targeted revision, the channel that lets interaction import information from outside the weights and exceed the reasoning/sampling ceiling (\Cref {sec:framework}). \textbf {(2)} As grounded \emph {evaluation}, it is the score that makes the gain measurable. Substituting the default VLM-on-a-screenshot judge (red lane) breaks \emph {both}: it is structurally blind to off-canvas overflow and fine overlap, so it neither scores the defect nor (as a reviewer) fixes it.\relax }{figure.caption.2}{}}
\newlabel{fig:concept@cref}{{[figure][1][]1}{[1][2][]3}}
\@writefile{toc}{\contentsline {section}{\numberline {2}The Grounded-Feedback Framework}{3}{section.2}\protected@file@percent }
\newlabel{sec:framework}{{2}{3}{The Grounded-Feedback Framework}{section.2}{}}
\newlabel{sec:framework@cref}{{[section][2][]2}{[1][3][]3}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}A feedback taxonomy by grounding}{4}{subsection.2.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Why grounding breaks the ceiling: a DPI bound}{4}{subsection.2.2}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The symmetric claim: ungrounded evaluation cannot measure the gain.}{4}{paragraph*.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Two in-token-space axes saturate. Interaction does not.} Measured code pass-rate vs.\ per-task token budget on the $15$ hard tasks ($3$-seed means, full table with SDs in \Cref  {tab:scaling-curves}). Reasoning-only plateaus at its information ceiling ($73.3\%$), and best-of-$N$ plateaus at $86.7\%$ even with an oracle (ground-truth) verifier (dotted). Both are functions of the frozen $(\Theta ,X)$ and flatten with budget, the latter at the high-probability support of the proposer's own output distribution. The two feedback-iterating strategies instead climb past the oracle-sampling ceiling to $\ge 97.8\%$ (harness: strict $100\%$), importing information from execution each cycle, the DPI prediction made concrete. These are measured points, not a schematic.\relax }}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:dpi}{{2}{5}{\textbf {Two in-token-space axes saturate. Interaction does not.} Measured code pass-rate vs.\ per-task token budget on the $15$ hard tasks ($3$-seed means, full table with SDs in \Cref {tab:scaling-curves}). Reasoning-only plateaus at its information ceiling ($73.3\%$), and best-of-$N$ plateaus at $86.7\%$ even with an oracle (ground-truth) verifier (dotted). Both are functions of the frozen $(\Theta ,X)$ and flatten with budget, the latter at the high-probability support of the proposer's own output distribution. The two feedback-iterating strategies instead climb past the oracle-sampling ceiling to $\ge 97.8\%$ (harness: strict $100\%$), importing information from execution each cycle, the DPI prediction made concrete. These are measured points, not a schematic.\relax }{figure.caption.5}{}}
\newlabel{fig:dpi@cref}{{[figure][2][]2}{[1][5][]5}}
